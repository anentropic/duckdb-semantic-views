# Phase 2 DDL round-trip integration test.
# Updated for keyword args support: DDL functions are now table functions
# (VTab) and require FROM syntax with keyword arguments.
#
# Exercises create_semantic_view, create_or_replace_semantic_view,
# create_semantic_view_if_not_exists, drop_semantic_view,
# drop_semantic_view_if_exists, list_semantic_views, and describe_semantic_view
# via the actual DuckDB extension LOAD mechanism.
#
# Requirements covered:
#   DDL-01: create_semantic_view() registers a view
#   DDL-02: drop_semantic_view() removes a registered view
#   DDL-03: create_or_replace_semantic_view() overwrites an existing definition
#   DDL-04: 6-arg STRUCT/LIST parameter interface
#   KWARG-01: keyword args syntax for DDL table functions
#
# Run via: just test  (make test_debug)

require semantic_views

# ============================================================
# 1. Create a semantic view -- DDL-01, DDL-04
# ============================================================

statement ok
SELECT * FROM create_semantic_view(
    'orders',
    tables := [{'alias': 'o', 'table': 'orders'}],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 'o'}],
    metrics := [{'name': 'revenue', 'expr': 'sum(amount)', 'source_table': 'o'}]
);

statement ok
SELECT * FROM create_semantic_view(
    'customers',
    tables := [{'alias': 'c', 'table': 'customers'}],
    dimensions := [{'name': 'country', 'expr': 'country', 'source_table': 'c'}],
    metrics := [{'name': 'count', 'expr': 'count(*)', 'source_table': 'c'}]
);

# ============================================================
# 2. list_semantic_views returns all registered views -- DDL-01
# ============================================================

# Two views should be present (orders + customers), sorted by name
query TT rowsort
SELECT name, base_table FROM list_semantic_views();
----
customers	customers
orders	orders

# ============================================================
# 3. describe_semantic_view returns the view name and base_table
# ============================================================

# Verify orders view name and base_table (avoid brittle JSON assertions)
query TT
SELECT name, base_table FROM describe_semantic_view('orders');
----
orders	orders

query TT
SELECT name, base_table FROM describe_semantic_view('customers');
----
customers	customers

# ============================================================
# 4. Duplicate create is an error -- DDL-01
# ============================================================

statement error
SELECT * FROM create_semantic_view(
    'orders',
    tables := [{'alias': 'o', 'table': 'orders'}],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 'o'}],
    metrics := [{'name': 'revenue', 'expr': 'sum(amount)', 'source_table': 'o'}]
);
----
already exists

# ============================================================
# 5. describe_semantic_view on unknown view is an error
# ============================================================

statement error
SELECT * FROM describe_semantic_view('nonexistent');
----
does not exist

# ============================================================
# 6. drop_semantic_view removes the view -- DDL-02
# ============================================================

statement ok
SELECT * FROM drop_semantic_view('orders');

# Orders should be gone from list
query TT rowsort
SELECT name, base_table FROM list_semantic_views();
----
customers	customers

# describe_semantic_view on the dropped view should error
statement error
SELECT * FROM describe_semantic_view('orders');
----
does not exist

# ============================================================
# 7. drop_semantic_view on nonexistent view is an error -- DDL-02
# ============================================================

statement error
SELECT * FROM drop_semantic_view('orders');
----
does not exist

# ============================================================
# 8. create_or_replace_semantic_view overwrites -- DDL-03
# ============================================================

statement ok
SELECT * FROM create_or_replace_semantic_view(
    'customers',
    tables := [{'alias': 'c', 'table': 'customers'}],
    dimensions := [{'name': 'country', 'expr': 'country', 'source_table': 'c'}],
    metrics := [{'name': 'count', 'expr': 'count(*)', 'source_table': 'c'},
     {'name': 'active_count', 'expr': 'count(distinct id)', 'source_table': 'c'}]
);

# Still only one customers view
query I
SELECT count(*) FROM list_semantic_views() WHERE name = 'customers';
----
1

# ============================================================
# 9. drop_semantic_view_if_exists is silent -- DDL-02
# ============================================================

statement ok
SELECT * FROM drop_semantic_view_if_exists('nonexistent_view');

statement ok
SELECT * FROM drop_semantic_view_if_exists('orders');

# ============================================================
# 10. Table functions are present with minimal args (DDL-04, DDL-05)
# ============================================================

statement ok
SELECT * FROM create_semantic_view('x_test');

statement ok
SELECT * FROM drop_semantic_view('x_test');

# ============================================================
# 11. Define a second view and verify list -- DDL-01
# ============================================================

statement ok
SELECT * FROM create_semantic_view(
    'products',
    tables := [{'alias': 'p', 'table': 'products'}],
    dimensions := [{'name': 'category', 'expr': 'category', 'source_table': 'p'}],
    metrics := [{'name': 'total', 'expr': 'sum(price)', 'source_table': 'p'}]
);

query TT rowsort
SELECT name, base_table FROM list_semantic_views();
----
customers	customers
products	products

# ============================================================
# 12. Multi-table view with join relationships -- DDL-04
# ============================================================

statement ok
SELECT * FROM create_semantic_view(
    'sales',
    tables := [{'alias': 'o', 'table': 'orders'}, {'alias': 'c', 'table': 'customers'}],
    relationships := [{'from_table': 'o', 'to_table': 'c',
      'join_columns': [{'from': 'customer_id', 'to': 'id'}]}],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 'o'},
     {'name': 'customer_name', 'expr': 'name', 'source_table': 'c'}],
    metrics := [{'name': 'revenue', 'expr': 'sum(amount)', 'source_table': 'o'}]
);

query TT rowsort
SELECT name, base_table FROM list_semantic_views();
----
customers	customers
products	products
sales	orders

# ============================================================
# 13. View with time dimensions -- DDL-04
# ============================================================

statement ok
SELECT * FROM create_semantic_view(
    'time_orders',
    tables := [{'alias': 'o', 'table': 'orders'}],
    dimensions := [{'name': 'status', 'expr': 'status', 'source_table': 'o'}],
    time_dimensions := [{'name': 'order_date', 'expr': 'created_at', 'granularity': 'month'}],
    metrics := [{'name': 'revenue', 'expr': 'sum(amount)', 'source_table': 'o'}]
);

query TT rowsort
SELECT name, base_table FROM list_semantic_views();
----
customers	customers
products	products
sales	orders
time_orders	orders

# ============================================================
# 14. Clean up: drop remaining views
# ============================================================

statement ok
SELECT * FROM drop_semantic_view('customers');

statement ok
SELECT * FROM drop_semantic_view('products');

statement ok
SELECT * FROM drop_semantic_view('sales');

statement ok
SELECT * FROM drop_semantic_view('time_orders');

query I
SELECT count(*) FROM list_semantic_views();
----
0

# ============================================================
# 15. create_semantic_view_if_not_exists -- silent no-op on duplicate
# ============================================================

# First call creates the view (normal behavior)
statement ok
SELECT * FROM create_semantic_view_if_not_exists(
    'idempotent_test',
    tables := [{'alias': 't', 'table': 'orders'}],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 't'}]
);

# Second call on same view name must NOT error (if_not_exists behavior)
statement ok
SELECT * FROM create_semantic_view_if_not_exists(
    'idempotent_test',
    tables := [{'alias': 't', 'table': 'orders'}],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 't'}]
);

# Clean up
statement ok
SELECT * FROM drop_semantic_view('idempotent_test');

# ============================================================
# 16. Keyword args syntax -- create_semantic_view with all named params (KWARG-01)
# ============================================================

statement ok
SELECT * FROM create_semantic_view(
    'kwarg_test',
    tables := [{'alias': 'o', 'table': 'orders'}],
    relationships := [],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 'o'}],
    time_dimensions := [],
    metrics := [{'name': 'revenue', 'expr': 'sum(amount)', 'source_table': 'o'}]
);

# Verify it was created
query TT
SELECT name, base_table FROM describe_semantic_view('kwarg_test');
----
kwarg_test	orders

# Clean up
statement ok
SELECT * FROM drop_semantic_view('kwarg_test');

# ============================================================
# 17. Mixed positional name + keyword args (KWARG-01)
# ============================================================

# Omitting optional params (relationships, time_dimensions) defaults to empty lists
statement ok
SELECT * FROM create_semantic_view(
    'mixed_test',
    tables := [{'alias': 'o', 'table': 'orders'}],
    dimensions := [{'name': 'status', 'expr': 'status', 'source_table': 'o'}],
    metrics := [{'name': 'total', 'expr': 'count(*)', 'source_table': 'o'}]
);

query TT
SELECT name, base_table FROM describe_semantic_view('mixed_test');
----
mixed_test	orders

statement ok
SELECT * FROM drop_semantic_view('mixed_test');
