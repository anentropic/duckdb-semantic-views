# Phase 26: PK/FK Join Resolution
# Tests: PK/FK ON clause synthesis, transitive join inclusion, LEFT JOIN,
#        graph validation errors (cycle, self-ref)

require semantic_views

# --- Setup: create test tables with p26_ prefix ---
statement ok
CREATE TABLE p26_customers (id INTEGER, name VARCHAR);

statement ok
INSERT INTO p26_customers VALUES (1, 'Alice'), (2, 'Bob');

statement ok
CREATE TABLE p26_orders (id INTEGER, customer_id INTEGER, amount DECIMAL(10,2));

statement ok
INSERT INTO p26_orders VALUES (1, 1, 100.00), (2, 1, 200.00), (3, 2, 50.00);

statement ok
CREATE TABLE p26_line_items (id INTEGER, order_id INTEGER, product VARCHAR, qty INTEGER);

statement ok
INSERT INTO p26_line_items VALUES (1, 1, 'Widget', 2), (2, 2, 'Gadget', 1), (3, 3, 'Widget', 3);

# --- Test 1: Basic PK/FK join (EXP-02) ---
statement ok
CREATE SEMANTIC VIEW p26_sales AS
  TABLES (
    o AS p26_orders PRIMARY KEY (id),
    c AS p26_customers PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    order_to_customer AS o(customer_id) REFERENCES c
  )
  DIMENSIONS (
    c.customer_name AS c.name
  )
  METRICS (
    o.total_amount AS sum(o.amount)
  );

# Query crossing join boundary (customer_name from c, total_amount from o)
query TR rowsort
SELECT * FROM semantic_view('p26_sales', dimensions := ['customer_name'], metrics := ['total_amount']);
----
Alice	300.00
Bob	50.00

# --- Test 2: Transitive join inclusion through 3 tables (EXP-04) ---
statement ok
CREATE SEMANTIC VIEW p26_detailed AS
  TABLES (
    o AS p26_orders PRIMARY KEY (id),
    c AS p26_customers PRIMARY KEY (id),
    li AS p26_line_items PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    order_to_customer AS o(customer_id) REFERENCES c,
    item_to_order AS li(order_id) REFERENCES o
  )
  DIMENSIONS (
    c.customer_name AS c.name,
    li.product AS li.product
  )
  METRICS (
    li.total_qty AS sum(li.qty)
  );

# Query from li to c: should auto-join through o
query TI rowsort
SELECT * FROM semantic_view('p26_detailed', dimensions := ['customer_name'], metrics := ['total_qty']);
----
Alice	3
Bob	3

# --- Test 3: Pruning -- query only base table metrics needs minimal joins ---
query TI rowsort
SELECT * FROM semantic_view('p26_detailed', dimensions := ['product'], metrics := ['total_qty']);
----
Gadget	1
Widget	5

# --- Test 4: LEFT JOIN preserves base table rows ---
# Add an order with no matching customer
statement ok
INSERT INTO p26_orders VALUES (4, 999, 75.00);

query TR rowsort
SELECT * FROM semantic_view('p26_sales', dimensions := ['customer_name'], metrics := ['total_amount']);
----
Alice	300.00
Bob	50.00
NULL	75.00

# --- Test 5: Graph validation errors (EXP-06) ---

# Cycle: a->b->a
statement error
CREATE SEMANTIC VIEW p26_cycle AS
  TABLES (
    a AS p26_orders PRIMARY KEY (id),
    b AS p26_customers PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    a_to_b AS a(customer_id) REFERENCES b,
    b_to_a AS b(id) REFERENCES a
  )
  DIMENSIONS (a.dim1 AS a.amount)
  METRICS (a.met1 AS sum(a.amount));
----
cycle detected

# Self-reference
statement error
CREATE SEMANTIC VIEW p26_selfref AS
  TABLES (
    o AS p26_orders PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    self_ref AS o(customer_id) REFERENCES o
  )
  DIMENSIONS (o.dim1 AS o.amount)
  METRICS (o.met1 AS sum(o.amount));
----
cannot reference itself

# --- Cleanup ---
statement ok
DROP SEMANTIC VIEW p26_sales;

statement ok
DROP SEMANTIC VIEW p26_detailed;

statement ok
DROP TABLE p26_line_items;

statement ok
DROP TABLE p26_orders;

statement ok
DROP TABLE p26_customers;
