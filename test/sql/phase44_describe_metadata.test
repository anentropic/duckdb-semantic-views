# Phase 44: DESCRIBE metadata properties (SHOW-06)
# Tests COMMENT, SYNONYMS, ACCESS_MODIFIER property rows in DESCRIBE output.

require semantic_views

# ============================================================
# Setup
# ============================================================

statement ok
CREATE TABLE p44d_orders (id INTEGER PRIMARY KEY, amount DECIMAL(10,2), order_date DATE);

statement ok
CREATE TABLE p44d_customers (id INTEGER PRIMARY KEY, name VARCHAR, region VARCHAR);

# Create a fully annotated semantic view
statement ok
CREATE SEMANTIC VIEW p44d_annotated
  COMMENT = 'Sales analysis view'
AS
  TABLES (
    o AS p44d_orders PRIMARY KEY (id)
      COMMENT = 'Orders fact table'
      WITH SYNONYMS = ('purchases', 'transactions'),
    c AS p44d_customers PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    orders_to_customers AS o(id) REFERENCES c
  )
  FACTS (
    PRIVATE o.raw_amount AS o.amount
      COMMENT = 'Raw order amount'
      WITH SYNONYMS = ('order_value')
  )
  DIMENSIONS (
    c.customer_name AS c.name
      COMMENT = 'Customer full name'
      WITH SYNONYMS = ('client_name'),
    o.order_date AS o.order_date
  )
  METRICS (
    o.total_amount AS SUM(o.amount)
      COMMENT = 'Total sales'
      WITH SYNONYMS = ('total_sales', 'revenue'),
    avg_amount AS total_amount * 0.1
      COMMENT = 'Ten percent of total'
  )

# ============================================================
# Test 1: View-level COMMENT row
# ============================================================

query TTTTT
SELECT * FROM describe_semantic_view('p44d_annotated') WHERE property = 'COMMENT' AND object_kind = '';
----
(empty)	(empty)	(empty)	COMMENT	Sales analysis view

# ============================================================
# Test 2: TABLE COMMENT and SYNONYMS rows
# ============================================================

query TTTTT rowsort
SELECT * FROM describe_semantic_view('p44d_annotated') WHERE object_kind = 'TABLE' AND property IN ('COMMENT', 'SYNONYMS');
----
TABLE	p44d_orders	(empty)	COMMENT	Orders fact table
TABLE	p44d_orders	(empty)	SYNONYMS	["purchases","transactions"]

# ============================================================
# Test 3: DIMENSION COMMENT and SYNONYMS rows
# ============================================================

query TTTTT rowsort
SELECT * FROM describe_semantic_view('p44d_annotated') WHERE object_kind = 'DIMENSION' AND property IN ('COMMENT', 'SYNONYMS');
----
DIMENSION	customer_name	p44d_customers	COMMENT	Customer full name
DIMENSION	customer_name	p44d_customers	SYNONYMS	["client_name"]

# ============================================================
# Test 4: FACT COMMENT, SYNONYMS, ACCESS_MODIFIER=PRIVATE
# ============================================================

query TTTTT rowsort
SELECT * FROM describe_semantic_view('p44d_annotated') WHERE object_kind = 'FACT' AND property IN ('COMMENT', 'SYNONYMS', 'ACCESS_MODIFIER');
----
FACT	raw_amount	p44d_orders	ACCESS_MODIFIER	PRIVATE
FACT	raw_amount	p44d_orders	COMMENT	Raw order amount
FACT	raw_amount	p44d_orders	SYNONYMS	["order_value"]

# ============================================================
# Test 5: METRIC COMMENT, SYNONYMS, ACCESS_MODIFIER=PUBLIC
# ============================================================

query TTTTT rowsort
SELECT * FROM describe_semantic_view('p44d_annotated') WHERE object_kind = 'METRIC' AND property IN ('COMMENT', 'SYNONYMS', 'ACCESS_MODIFIER');
----
METRIC	total_amount	p44d_orders	ACCESS_MODIFIER	PUBLIC
METRIC	total_amount	p44d_orders	COMMENT	Total sales
METRIC	total_amount	p44d_orders	SYNONYMS	["total_sales","revenue"]

# ============================================================
# Test 6: DERIVED_METRIC ACCESS_MODIFIER=PUBLIC and COMMENT
# ============================================================

query TTTTT rowsort
SELECT * FROM describe_semantic_view('p44d_annotated') WHERE object_kind = 'DERIVED_METRIC' AND property IN ('COMMENT', 'ACCESS_MODIFIER');
----
DERIVED_METRIC	avg_amount	(empty)	ACCESS_MODIFIER	PUBLIC
DERIVED_METRIC	avg_amount	(empty)	COMMENT	Ten percent of total

# ============================================================
# Test 7: View WITHOUT annotations — no COMMENT/SYNONYMS rows,
# but ACCESS_MODIFIER still appears for facts and metrics
# ============================================================

statement ok
CREATE SEMANTIC VIEW p44d_plain AS
  TABLES (o AS p44d_orders PRIMARY KEY (id))
  FACTS (o.raw_amount AS o.amount)
  DIMENSIONS (o.order_date AS o.order_date)
  METRICS (o.total AS SUM(o.amount))

# No view-level COMMENT
query I
SELECT COUNT(*) FROM describe_semantic_view('p44d_plain') WHERE property = 'COMMENT';
----
0

# No SYNONYMS
query I
SELECT COUNT(*) FROM describe_semantic_view('p44d_plain') WHERE property = 'SYNONYMS';
----
0

# ACCESS_MODIFIER present for fact and metric (both PUBLIC)
query TTTTT rowsort
SELECT * FROM describe_semantic_view('p44d_plain') WHERE property = 'ACCESS_MODIFIER';
----
FACT	raw_amount	p44d_orders	ACCESS_MODIFIER	PUBLIC
METRIC	total	p44d_orders	ACCESS_MODIFIER	PUBLIC

# ============================================================
# Cleanup
# ============================================================

statement ok
DROP SEMANTIC VIEW p44d_annotated

statement ok
DROP SEMANTIC VIEW p44d_plain

statement ok
DROP TABLE p44d_orders

statement ok
DROP TABLE p44d_customers
