# Phase 65.1 Plan 11 — WR-07 / WR-08 / D-14 / D-15 / D-16 hard-error coverage
# for the bind-time LIMIT 0 type-inference probe.
#
# Before Plan 11, two silent fallbacks lived behind the type-inference probe:
#   WR-07 (cpp/src/shim.cpp `sv_resolve_output_logical_types`) — if the C++
#         LIMIT 0 probe failed, the function fell back to a type_id-only
#         declaration that mapped DUCKDB_TYPE_DECIMAL → DECIMAL(18,3) and
#         DUCKDB_TYPE_LIST → LIST(VARCHAR), masking real errors.
#   WR-08 (src/query/table_function.rs `try_infer_schema`) — if the Rust
#         LIMIT 0 probe failed, the function returned `None` (via `.ok()?`)
#         and the caller substituted `vec![0u32; names.len()]`
#         (DUCKDB_TYPE_INVALID, declared as VARCHAR at query time).
#
# Both surfaces now propagate the underlying DuckDB error verbatim:
#   WR-07 raises BinderException with prefix
#         "semantic_view: failed to infer column types via LIMIT 0 probe:"
#   WR-08 surfaces via error_buf + the C++ binder re-raise as
#         "Binder Error: semantic_view: semantic_view: type inference \
#          failed for query `<sql>`: <inner>"
#
# In practice the Rust LIMIT 0 probe runs FIRST (to obtain type IDs for the
# wire format), so a broken expanded SQL fails via WR-08 before WR-07's
# DECIMAL-only second probe is reached. This file pins the WR-08 surface
# for the broken-METRIC case; WR-07's distinct wording is exercised by the
# C++ branch unreachable from SQL alone (covered by structural inspection
# of cpp/src/shim.cpp at lines containing
# "failed to infer column types via LIMIT 0 probe").
#
# Plan 06 already added the CHANGELOG `### Changed` entry covering this
# user-visible behaviour shift (D-16).

require semantic_views

statement ok
LOAD semantic_views;

# ---- B1: happy path regression guard ---------------------------------------
# A valid semantic view + query must still succeed post-promotion.
# Confirms the LIMIT 0 probe path resolves types cleanly when the underlying
# expressions compile, i.e. the new hard-error paths did NOT regress the
# common case.

statement ok
CREATE TABLE p651_orders (order_id INTEGER, total DECIMAL(10,2));

statement ok
INSERT INTO p651_orders VALUES (1, 10.50), (2, 20.00), (3, 5.25);

statement ok
CREATE SEMANTIC VIEW v_good_probe
  AS
    TABLES (o AS p651_orders PRIMARY KEY (order_id))
    DIMENSIONS (o.order_id AS o.order_id)
    METRICS (o.total AS SUM(o.total));

query I
SELECT COUNT(*) FROM semantic_view('v_good_probe', metrics := ['total'])
----
1

# ---- B2: WR-08 hard-error surface ------------------------------------------
# A METRIC expression referencing a column that doesn't exist on the
# underlying base table. DDL creates the view (Phase 65 deliberately does
# not run the expressions at CREATE time — the binder probe is the
# read-side gate). At query time the LIMIT 0 probe in
# `sv_semantic_view_bind_rust::try_infer_schema` raises a Binder Error
# (because "o.no_such_column" cannot be bound); Plan 11 / WR-08 / D-15
# now surfaces that error verbatim via `error_buf` + the C++ binder
# re-raise, instead of swallowing it through `.ok()?` and declaring the
# column as `DUCKDB_TYPE_INVALID` (silent VARCHAR placeholder at query
# time).
#
# The substring "type inference failed for query" is the stable WR-08
# prefix (from the Rust write_err call in
# `src/query/table_function.rs`). The substring "Table \"o\" does not
# have a column named \"no_such_column\"" is the verbatim inner DuckDB
# diagnostic now made user-visible.

statement ok
CREATE SEMANTIC VIEW v_bad_probe
  AS
    TABLES (o AS p651_orders PRIMARY KEY (order_id))
    DIMENSIONS (o.order_id AS o.order_id)
    METRICS (o.bogus AS SUM(o.no_such_column));

statement error
SELECT * FROM semantic_view('v_bad_probe', metrics := ['bogus'])
----
type inference failed for query

# Cleanup: drop both semantic views and the base table so subsequent tests
# in the runner cascade see a clean catalog.

statement ok
DROP SEMANTIC VIEW v_good_probe;

statement ok
DROP SEMANTIC VIEW v_bad_probe;

statement ok
DROP TABLE p651_orders;
