# FF-3 (code-review 2026-07-02): ATTACH / single-catalog contract.
#
# Semantic views are single-catalog: the semantic_layer._definitions table is
# created only in the database the extension was LOADed into (the primary), and
# every read runs on a fresh per-call connection that resolves against that
# primary catalog. Issuing semantic-view DDL while USE-d into a *different*
# (e.g. ATTACHed) database used to fail with a cryptic "schema semantic_layer
# does not exist" (CREATE) or silently write a row the primary-pinned reads
# never see. A single-catalog guard now raises an actionable error instead.

require semantic_views

statement ok
CREATE TABLE base (id INTEGER PRIMARY KEY, region VARCHAR, amt DECIMAL(10,2));

statement ok
INSERT INTO base VALUES (1, 'US', 10.00), (2, 'EU', 20.00);

# Normal single-catalog usage in the primary catalog works.
statement ok
CREATE SEMANTIC VIEW v AS
  TABLES (b AS base PRIMARY KEY (id))
  DIMENSIONS (b.region AS b.region)
  METRICS (b.total AS SUM(b.amt));

query I
SELECT name FROM list_semantic_views();
----
v

# Attach a second catalog and switch the session into it.
statement ok
ATTACH ':memory:' AS adb;

statement ok
USE adb;

# ------------------------------------------------------------------
# FF-3: semantic-view DDL from the wrong catalog fails with an
# actionable single-catalog error (not a cryptic "schema does not
# exist" and not a silent cross-catalog write).
# ------------------------------------------------------------------

statement error
CREATE SEMANTIC VIEW v2 AS
  TABLES (b AS base PRIMARY KEY (id))
  DIMENSIONS (b.region AS b.region)
  METRICS (b.total AS SUM(b.amt));
----
single-catalog

statement error
DROP SEMANTIC VIEW v;
----
single-catalog

statement error
ALTER SEMANTIC VIEW v RENAME TO v_renamed;
----
single-catalog

# Reads stay pinned to the managed (primary) catalog regardless of USE.
query I
SELECT name FROM list_semantic_views();
----
v

# Switching back to the managed catalog restores normal operation.
statement ok
USE memory;

statement ok
DROP SEMANTIC VIEW v;

query I
SELECT count(*) FROM list_semantic_views();
----
0
