# Phase 62 Wave 3 — caret rendering coverage for CREATE error paths.
#
# Plans 02-03 restored caret rendering via parse_function on FALLBACK_OVERRIDE
# deferral. parser_override returns rc=2 on validation errors; the default
# parser fails on the unrecognised DDL prefix; DuckDB calls our
# parse_function which returns DISPLAY_EXTENSION_ERROR with error_location
# (byte offset into the user input). ParserException::SyntaxError renders
# `LINE 1: ... ^`.
#
# Behavioural properties pinned (from RESEARCH.md §6):
#   B1: caret renders for malformed CREATE (missing '(')
#   B2: caret renders for clause typo (`TBLES` → suggest `TABLES`)
#   B3: caret renders for prefix near-miss (`CRETAE`)
#
# sqllogictest matches the substring of the FULL rendered error
# including the caret line. Substring `LINE 1:` proves caret rendering is
# happening; substring `Did you mean` pins the near-miss helper text.

require semantic_views

statement ok
LOAD semantic_views;

statement ok
CREATE TABLE t(id INTEGER PRIMARY KEY);

# B1: missing '(' after TABLES -- caret should land just after `TABLES `
statement error
CREATE SEMANTIC VIEW v_bad_paren AS TABLES t;
----
LINE 1:

# B2: clause keyword typo (TBLES) -- validator emits "did you mean 'TABLES'?"
statement error
CREATE SEMANTIC VIEW v_bad_kw AS TBLES (t);
----
did you mean 'TABLES'

# B3: prefix near-miss (CRETAE -> CREATE)
statement error
CRETAE SEMANTIC VIEW v_typo AS TABLES (t);
----
Did you mean 'CREATE SEMANTIC VIEW'
