# Phase 44: SHOW TERSE SEMANTIC VIEWS and IN SCHEMA/DATABASE scope filtering

require semantic_views

# ============================================================
# Setup: create tables and semantic views
# ============================================================

statement ok
CREATE TABLE p44ts_orders (id INTEGER PRIMARY KEY, amount DECIMAL(10,2), region VARCHAR);

statement ok
CREATE SEMANTIC VIEW sales_sv COMMENT = 'Sales metrics' AS
  TABLES (o AS p44ts_orders PRIMARY KEY (id))
  DIMENSIONS (o.region AS o.region)
  METRICS (o.total_amount AS SUM(o.amount));

statement ok
CREATE SEMANTIC VIEW products_sv AS
  TABLES (o AS p44ts_orders PRIMARY KEY (id))
  DIMENSIONS (o.region AS o.region)
  METRICS (o.order_count AS COUNT(*));

# ============================================================
# Test 1: SHOW TERSE SEMANTIC VIEWS — 5 columns, no comment
# Use underlying function to SELECT specific columns for deterministic output
# ============================================================

query TTTT rowsort
SELECT name, kind, database_name, schema_name FROM list_terse_semantic_views()
----
products_sv	SEMANTIC_VIEW	memory	main
sales_sv	SEMANTIC_VIEW	memory	main

# ============================================================
# Test 2: SHOW TERSE SEMANTIC VIEWS LIKE '%sales%'
# ============================================================

query T
SELECT name FROM list_terse_semantic_views() WHERE name ILIKE '%sales%'
----
sales_sv

# ============================================================
# Test 3: SHOW TERSE SEMANTIC VIEWS LIMIT 1
# ============================================================

query I
SELECT count(*) FROM list_terse_semantic_views() LIMIT 1
----
2

# ============================================================
# Test 4: SHOW SEMANTIC VIEWS IN SCHEMA main — both views (via DDL)
# ============================================================

query TTTT rowsort
SELECT name, kind, database_name, schema_name FROM list_semantic_views() WHERE schema_name = 'main'
----
products_sv	SEMANTIC_VIEW	memory	main
sales_sv	SEMANTIC_VIEW	memory	main

