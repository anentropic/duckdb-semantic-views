# Phase 31/33: End-to-end integration test for fan trap detection
# Tests that queries crossing fan-out boundaries (reverse ManyToOne) are blocked
# with descriptive errors, while safe queries succeed normally.
# Phase 33: Cardinality keywords removed; cardinality inferred from PK/UNIQUE.

require semantic_views

# ============================================================
# Setup: create physical tables with known data
# ============================================================

statement ok
CREATE TABLE p31_orders (id INTEGER, customer_id INTEGER, region VARCHAR);

statement ok
INSERT INTO p31_orders VALUES (1, 10, 'East'), (2, 20, 'West');

statement ok
CREATE TABLE p31_line_items (id INTEGER, order_id INTEGER, extended_price DOUBLE, status VARCHAR);

statement ok
INSERT INTO p31_line_items VALUES
    (1, 1, 100.00, 'shipped'),
    (2, 1, 200.00, 'pending'),
    (3, 2, 150.00, 'shipped');

statement ok
CREATE TABLE p31_customers (id INTEGER, name VARCHAR, segment VARCHAR);

statement ok
INSERT INTO p31_customers VALUES (10, 'Alice', 'Enterprise'), (20, 'Bob', 'SMB');

# ============================================================
# Test 1: DDL with inferred cardinality (no keywords)
# li(order_id) REFERENCES o -> ManyToOne (order_id not PK/UNIQUE on li)
# o(customer_id) REFERENCES c -> ManyToOne (customer_id not PK/UNIQUE on o)
# ============================================================

statement ok
CREATE SEMANTIC VIEW p31_sales AS
  TABLES (
    o AS p31_orders PRIMARY KEY (id),
    li AS p31_line_items PRIMARY KEY (id),
    c AS p31_customers PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    li_to_order AS li(order_id) REFERENCES o,
    order_to_customer AS o(customer_id) REFERENCES c
  )
  DIMENSIONS (
    o.region AS o.region,
    c.segment AS c.segment,
    li.status AS li.status
  )
  METRICS (
    li.revenue AS SUM(li.extended_price),
    o.order_count AS COUNT(*)
  );

# ============================================================
# Test 2: Safe query -- metric from li, dimension from o
# li.revenue (from li) + o.region (from o): li->o is ManyToOne, safe
# East: SUM(100 + 200) = 300, West: SUM(150) = 150
# ============================================================

query TR rowsort
SELECT * FROM semantic_view('p31_sales', dimensions := ['region'], metrics := ['revenue']);
----
East	300.0
West	150.0

# ============================================================
# Test 3: Fan trap -- metric from o, dimension from li (blocked)
# o.order_count (from o) + li.status (from li):
# o->li is reverse of li->o ManyToOne = fan-out
# ============================================================

statement error
SELECT * FROM semantic_view('p31_sales', dimensions := ['status'], metrics := ['order_count']);
----
fan trap detected

# ============================================================
# Test 4: Safe query -- metric from li, dimension from c
# li.revenue (from li) + c.segment (from c): li->o->c is ManyToOne chain, safe
# Enterprise: SUM(100+200) = 300, SMB: SUM(150) = 150
# ============================================================

query TR rowsort
SELECT * FROM semantic_view('p31_sales', dimensions := ['segment'], metrics := ['revenue']);
----
Enterprise	300.0
SMB	150.0

# ============================================================
# Test 5: OneToOne inferred (FK matches PK on from-side -> always safe)
# o(id) REFERENCES d: id is PK on o -> OneToOne inferred
# ============================================================

statement ok
DROP SEMANTIC VIEW p31_sales;

statement ok
CREATE TABLE p31_order_details (id INTEGER, note VARCHAR);

statement ok
INSERT INTO p31_order_details VALUES (1, 'rush'), (2, 'standard');

statement ok
CREATE SEMANTIC VIEW p31_oto AS
  TABLES (
    o AS p31_orders PRIMARY KEY (id),
    d AS p31_order_details PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    order_detail AS o(id) REFERENCES d
  )
  DIMENSIONS (
    o.region AS o.region,
    d.note AS d.note
  )
  METRICS (
    o.order_count AS COUNT(*),
    d.detail_count AS COUNT(*)
  );

# Both directions safe with OneToOne

query TR rowsort
SELECT * FROM semantic_view('p31_oto', dimensions := ['note'], metrics := ['order_count']);
----
rush	1
standard	1

query TR rowsort
SELECT * FROM semantic_view('p31_oto', dimensions := ['region'], metrics := ['detail_count']);
----
East	1
West	1

# ============================================================
# Test 6: Default cardinality (no keyword = inferred ManyToOne)
# ============================================================

statement ok
DROP SEMANTIC VIEW p31_oto;

statement ok
CREATE SEMANTIC VIEW p31_default AS
  TABLES (
    o AS p31_orders PRIMARY KEY (id),
    li AS p31_line_items PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    li_to_order AS li(order_id) REFERENCES o
  )
  DIMENSIONS (
    o.region AS o.region,
    li.status AS li.status
  )
  METRICS (
    li.revenue AS SUM(li.extended_price),
    o.order_count AS COUNT(*)
  );

# Inferred ManyToOne: li->o is safe, o->li is fan-out

query TR rowsort
SELECT * FROM semantic_view('p31_default', dimensions := ['region'], metrics := ['revenue']);
----
East	300.0
West	150.0

statement error
SELECT * FROM semantic_view('p31_default', dimensions := ['status'], metrics := ['order_count']);
----
fan trap detected

# ============================================================
# Test 7: Fan trap with derived metric
# ============================================================

statement ok
DROP SEMANTIC VIEW p31_default;

statement ok
CREATE SEMANTIC VIEW p31_derived AS
  TABLES (
    o AS p31_orders PRIMARY KEY (id),
    li AS p31_line_items PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    li_to_order AS li(order_id) REFERENCES o
  )
  DIMENSIONS (
    o.region AS o.region,
    li.status AS li.status
  )
  METRICS (
    li.revenue AS SUM(li.extended_price),
    o.order_count AS COUNT(*),
    avg_revenue AS revenue / order_count
  );

# Derived metric avg_revenue depends on order_count (from o).
# Querying with li.status means traversal o->li which is fan-out.

statement error
SELECT * FROM semantic_view('p31_derived', dimensions := ['status'], metrics := ['avg_revenue']);
----
fan trap detected

# But querying with o.region is safe (no fan-out traversal needed)
# East: revenue=300, order_count=2, avg=150.0
# West: revenue=150, order_count=1, avg=150.0

query TR rowsort
SELECT * FROM semantic_view('p31_derived', dimensions := ['region'], metrics := ['avg_revenue']);
----
East	150.0
West	150.0

# ============================================================
# Cleanup
# ============================================================

statement ok
DROP SEMANTIC VIEW p31_derived;

statement ok
DROP TABLE p31_order_details;

statement ok
DROP TABLE p31_line_items;

statement ok
DROP TABLE p31_orders;

statement ok
DROP TABLE p31_customers;
