# Phase 47: Semi-additive metrics
# Tests SEMI-01 through SEMI-05: NON ADDITIVE BY parsing, snapshot queries,
# effectively-regular behavior, mixed metrics, fan trap interaction

require semantic_views

# ========================================
# Setup: accounts + customers tables
# ========================================

statement ok
CREATE TABLE p47_customers (id INTEGER PRIMARY KEY, name VARCHAR);

statement ok
INSERT INTO p47_customers VALUES (1, 'Alice'), (2, 'Bob');

statement ok
CREATE TABLE p47_accounts (
    id INTEGER PRIMARY KEY,
    customer_id INTEGER,
    report_date DATE,
    balance DECIMAL(10,2)
);

statement ok
INSERT INTO p47_accounts VALUES
    (1, 1, '2024-01-01', 100.00),
    (2, 1, '2024-01-02', 150.00),
    (3, 1, '2024-01-03', 200.00),
    (4, 2, '2024-01-01', 300.00),
    (5, 2, '2024-01-02', 250.00);

# ========================================
# Test 1: Basic semi-additive metric DDL
# ========================================

statement ok
CREATE SEMANTIC VIEW p47_account_view AS
TABLES (
    a AS p47_accounts PRIMARY KEY (id),
    c AS p47_customers PRIMARY KEY (id)
)
RELATIONSHIPS (
    acct_cust AS a(customer_id) REFERENCES c
)
DIMENSIONS (
    c.customer_name AS c.name,
    a.report_date AS a.report_date
)
METRICS (
    a.total_balance NON ADDITIVE BY (report_date) AS SUM(a.balance)
)

# ========================================
# Test 2: Query semi-additive metric (NA dim NOT in query)
# Latest balance per customer (snapshot at most recent date).
# The default direction (ASC) selects the LATEST snapshot, matching Snowflake
# (F-1): no DESC needed for "latest".
# Alice: latest is 2024-01-03 -> 200.00
# Bob: latest is 2024-01-02 -> 250.00
# ========================================

query TR
SELECT * FROM semantic_view('p47_account_view', dimensions := ['customer_name'], metrics := ['total_balance']) ORDER BY 1;
----
Alice	200.00
Bob	250.00

# ========================================
# Phase 67 A2: shape assertions pinning semi-additive snapshot CTE emission
# Pin RANK() OVER, __sv_rn alias, and qualified 3-part FROM.
# (SG-4: RANK, not ROW_NUMBER, so rows tied at the snapshot value all
# aggregate; the __sv_rn column name is unchanged.)
# Idiom: explain_semantic_view + WHERE explain_output LIKE '%fragment%' (D-02/D-07).
# ========================================

query I
SELECT count(*) > 0 FROM explain_semantic_view('p47_account_view', dimensions := ['customer_name'], metrics := ['total_balance']) WHERE explain_output LIKE '%RANK() OVER%';
----
true

query I
SELECT count(*) > 0 FROM explain_semantic_view('p47_account_view', dimensions := ['customer_name'], metrics := ['total_balance']) WHERE explain_output LIKE '%__sv_rn%';
----
true

query I
SELECT count(*) > 0 FROM explain_semantic_view('p47_account_view', dimensions := ['customer_name'], metrics := ['total_balance']) WHERE explain_output LIKE '%FROM "memory"."main"."p47_accounts"%';
----
true

# ========================================
# Test 3: Semi-additive with NA dim IN query
# When report_date IS in dims, metric acts as regular
# (Snowflake semantics: no snapshot filtering when NA dim is queried)
# All rows returned with their actual balance values
# ========================================

query TTR
SELECT * FROM semantic_view('p47_account_view', dimensions := ['customer_name', 'report_date'], metrics := ['total_balance']) ORDER BY 1, 2;
----
Alice	2024-01-01	100.00
Alice	2024-01-02	150.00
Alice	2024-01-03	200.00
Bob	2024-01-01	300.00
Bob	2024-01-02	250.00

# ========================================
# Test 4: NON ADDITIVE BY validation
# Reference nonexistent dimension -> error
# ========================================

statement error
CREATE SEMANTIC VIEW p47_bad_na AS
TABLES (a AS p47_accounts PRIMARY KEY (id))
DIMENSIONS (a.report_date AS a.report_date)
METRICS (a.total_balance NON ADDITIVE BY (nonexistent_dim) AS SUM(a.balance))
----
does not match any declared dimension

# ========================================
# Test 5: Mixed regular + semi-additive metrics
# SG-5: a metric co-queried with an ACTIVE semi-additive metric must be a
# single decomposable aggregate call (SUM/COUNT/AVG/MIN/MAX over a plain
# argument). COUNT(*) is NOT decomposable — the snapshot CTE cannot capture
# `*` as a per-row column — so co-querying it now errors instead of
# producing a silently wrong (NULL-sensitive, arbitrary-column) count.
# ========================================

statement ok
CREATE SEMANTIC VIEW p47_mixed_view AS
TABLES (
    a AS p47_accounts PRIMARY KEY (id),
    c AS p47_customers PRIMARY KEY (id)
)
RELATIONSHIPS (
    acct_cust AS a(customer_id) REFERENCES c
)
DIMENSIONS (
    c.customer_name AS c.name,
    a.report_date AS a.report_date
)
METRICS (
    a.row_count AS COUNT(*),
    a.total_balance NON ADDITIVE BY (report_date) AS SUM(a.balance)
)

statement error
SELECT * FROM semantic_view('p47_mixed_view', dimensions := ['customer_name'], metrics := ['row_count', 'total_balance']);
----
cannot be co-queried with semi-additive metric 'total_balance'

# COUNT(*) alone (no active semi-additive metric in the query) still takes
# the standard aggregation path: Alice has 3 account rows, Bob has 2.
query TI
SELECT * FROM semantic_view('p47_mixed_view', dimensions := ['customer_name'], metrics := ['row_count']) ORDER BY 1;
----
Alice	3
Bob	2

# A decomposable regular metric CAN be co-queried: COUNT(a.id) counts all
# rows while total_balance snapshots the latest date.
# Alice: 3 rows, latest (2024-01-03) balance = 200.00
# Bob:   2 rows, latest (2024-01-02) balance = 250.00
statement ok
CREATE SEMANTIC VIEW p47_mixed_view2 AS
TABLES (
    a AS p47_accounts PRIMARY KEY (id),
    c AS p47_customers PRIMARY KEY (id)
)
RELATIONSHIPS (
    acct_cust AS a(customer_id) REFERENCES c
)
DIMENSIONS (
    c.customer_name AS c.name,
    a.report_date AS a.report_date
)
METRICS (
    a.row_count AS COUNT(a.id),
    a.total_balance NON ADDITIVE BY (report_date) AS SUM(a.balance)
)

query TIR
SELECT * FROM semantic_view('p47_mixed_view2', dimensions := ['customer_name'], metrics := ['row_count', 'total_balance']) ORDER BY 1;
----
Alice	3	200.00
Bob	2	250.00

# ========================================
# Test 6: GET_DDL round-trip with NON ADDITIVE BY
# ========================================

query I
SELECT GET_DDL('SEMANTIC_VIEW', 'p47_account_view') LIKE '%NON ADDITIVE BY%';
----
true

# ========================================
# Test 7: DESCRIBE shows NON_ADDITIVE_BY
# ========================================

query TTTTT
SELECT * FROM describe_semantic_view('p47_account_view') WHERE property = 'NON_ADDITIVE_BY';
----
METRIC	total_balance	p47_accounts	NON_ADDITIVE_BY	report_date NULLS LAST

# ========================================
# Test 8: Global aggregate (no dims)
# Uses single-entity data to ensure deterministic result.
# Default (ASC) selects the latest snapshot (F-1): rn=1 is the row with
# 2024-01-03 (balance=200.00). SUM of that single snapshot row = 200.00.
# ========================================

statement ok
CREATE TABLE p47_single_acct (
    id INTEGER PRIMARY KEY,
    report_date DATE,
    balance DECIMAL(10,2)
);

statement ok
INSERT INTO p47_single_acct VALUES
    (1, '2024-01-01', 100.00),
    (2, '2024-01-02', 150.00),
    (3, '2024-01-03', 200.00);

statement ok
CREATE SEMANTIC VIEW p47_global_view AS
TABLES (a AS p47_single_acct PRIMARY KEY (id))
DIMENSIONS (a.report_date AS a.report_date)
METRICS (
    a.latest_balance NON ADDITIVE BY (report_date) AS SUM(a.balance)
)

query R
SELECT * FROM semantic_view('p47_global_view', metrics := ['latest_balance']);
----
200.00

# ========================================
# Test 9 (TC-7a / SG-4 data-level): ties at the snapshot value aggregate
# Alice has TWO rows at her latest date 2024-01-03. RANK() gives both rows
# rank 1, so the snapshot SUM includes both: 120.00 + 80.00 = 200.00.
# (ROW_NUMBER() = 1 would have kept ONE arbitrary row: 120.00 or 80.00,
# nondeterministic run to run.)
# Alice rows: (2024-01-01, 999.00), (2024-01-03, 120.00), (2024-01-03, 80.00)
#   -> snapshot sum = 200.00
# Bob rows: (2024-01-02, 300.00) -> 300.00
# ========================================

statement ok
CREATE TABLE p47_tie_accounts (
    id INTEGER PRIMARY KEY,
    customer_name VARCHAR,
    report_date DATE,
    balance DECIMAL(10,2)
);

statement ok
INSERT INTO p47_tie_accounts VALUES
    (1, 'Alice', '2024-01-01', 999.00),
    (2, 'Alice', '2024-01-03', 120.00),
    (3, 'Alice', '2024-01-03', 80.00),
    (4, 'Bob',   '2024-01-02', 300.00);

statement ok
CREATE SEMANTIC VIEW p47_tie_view AS
TABLES (a AS p47_tie_accounts PRIMARY KEY (id))
DIMENSIONS (
    a.customer_name AS a.customer_name,
    a.report_date AS a.report_date
)
METRICS (
    a.total_balance NON ADDITIVE BY (report_date) AS SUM(a.balance)
)

query TR
SELECT * FROM semantic_view('p47_tie_view', dimensions := ['customer_name'], metrics := ['total_balance']) ORDER BY 1;
----
Alice	200.00
Bob	300.00

# Global aggregate (no dims): the latest date overall is 2024-01-03, held by
# Alice's two tied rows -> 120.00 + 80.00 = 200.00.
query R
SELECT * FROM semantic_view('p47_tie_view', metrics := ['total_balance']);
----
200.00

# ========================================
# Test 10 (TC-7b): NULLs in the NA ordering column
# The RANK ORDER BY keeps the declared NULLS ordering (only the direction is
# reversed for the latest/earliest selection, F-1), so NULLS FIRST lets a
# NULL-dated row outrank every dated row, while NULLS LAST makes the latest
# non-NULL date win instead.
# Alice rows: (NULL, 40.00), (2024-01-02, 150.00), (2024-01-01, 100.00)
#   NULLS FIRST: rank 1 = the NULL row       -> 40.00
#   NULLS LAST:  rank 1 = latest 2024-01-02  -> 150.00
# Bob rows: (2024-01-01, 300.00) only -> 300.00 under both orderings
# ========================================

statement ok
CREATE TABLE p47_null_accounts (
    id INTEGER PRIMARY KEY,
    customer_name VARCHAR,
    report_date DATE,
    balance DECIMAL(10,2)
);

statement ok
INSERT INTO p47_null_accounts VALUES
    (1, 'Alice', NULL,         40.00),
    (2, 'Alice', '2024-01-02', 150.00),
    (3, 'Alice', '2024-01-01', 100.00),
    (4, 'Bob',   '2024-01-01', 300.00);

statement ok
CREATE SEMANTIC VIEW p47_nulls_first_view AS
TABLES (a AS p47_null_accounts PRIMARY KEY (id))
DIMENSIONS (
    a.customer_name AS a.customer_name,
    a.report_date AS a.report_date
)
METRICS (
    a.latest_balance NON ADDITIVE BY (report_date NULLS FIRST) AS SUM(a.balance)
)

query TR
SELECT * FROM semantic_view('p47_nulls_first_view', dimensions := ['customer_name'], metrics := ['latest_balance']) ORDER BY 1;
----
Alice	40.00
Bob	300.00

statement ok
CREATE SEMANTIC VIEW p47_nulls_last_view AS
TABLES (a AS p47_null_accounts PRIMARY KEY (id))
DIMENSIONS (
    a.customer_name AS a.customer_name,
    a.report_date AS a.report_date
)
METRICS (
    a.latest_balance NON ADDITIVE BY (report_date NULLS LAST) AS SUM(a.balance)
)

query TR
SELECT * FROM semantic_view('p47_nulls_last_view', dimensions := ['customer_name'], metrics := ['latest_balance']) ORDER BY 1;
----
Alice	150.00
Bob	300.00

# ========================================
# Test 11 (F-1): explicit DESC now selects the EARLIEST snapshot — the mirror
# of the ASC/latest default. This is the behavioural change: before F-1, DESC
# meant "latest". Global aggregate (no dims): the earliest date overall is
# 2024-01-01, held by Alice (100.00) and Bob (300.00) -> 400.00.
# ========================================

statement ok
CREATE SEMANTIC VIEW p47_earliest_view AS
TABLES (a AS p47_accounts PRIMARY KEY (id))
DIMENSIONS (a.report_date AS a.report_date)
METRICS (
    a.earliest_balance NON ADDITIVE BY (report_date DESC) AS SUM(a.balance)
)

query R
SELECT * FROM semantic_view('p47_earliest_view', metrics := ['earliest_balance']);
----
400.00

statement ok
DROP SEMANTIC VIEW IF EXISTS p47_earliest_view;

# ========================================
# Cleanup
# ========================================

statement ok
DROP SEMANTIC VIEW IF EXISTS p47_nulls_last_view;

statement ok
DROP SEMANTIC VIEW IF EXISTS p47_nulls_first_view;

statement ok
DROP SEMANTIC VIEW IF EXISTS p47_tie_view;

statement ok
DROP SEMANTIC VIEW IF EXISTS p47_global_view;

statement ok
DROP SEMANTIC VIEW IF EXISTS p47_mixed_view2;

statement ok
DROP SEMANTIC VIEW IF EXISTS p47_mixed_view;

statement ok
DROP SEMANTIC VIEW IF EXISTS p47_account_view;

statement ok
DROP TABLE IF EXISTS p47_null_accounts;

statement ok
DROP TABLE IF EXISTS p47_tie_accounts;

statement ok
DROP TABLE IF EXISTS p47_single_acct;

statement ok
DROP TABLE IF EXISTS p47_accounts;

statement ok
DROP TABLE IF EXISTS p47_customers;
