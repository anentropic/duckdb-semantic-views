# Phase 68 Plan 03 (B1) / TECH-DEBT #25: NON ADDITIVE BY accepts quoted
# identifiers with literal whitespace AND dotted paths (D-08). Mirrors the
# Phase 67 Plan 02 / TECH-DEBT #24 fix to parse_single_table_entry — the
# split_whitespace shred at the dim_name slot is replaced with the
# identifier-aware find_identifier_end helper.

require semantic_views

statement ok
CREATE TABLE p68_b1_orders (id BIGINT, "order date" DATE, qty BIGINT);

statement ok
INSERT INTO p68_b1_orders VALUES (1, DATE '2026-01-01', 10), (2, DATE '2026-01-02', 20);

# ========================================
# Scenario 1 — quoted identifier with internal whitespace as NAB dimension
# Before the B1 fix, split_whitespace would shred `"order date"` into two
# tokens (`"order` + `date"`) and parse_non_additive_dims would fail with
# "Unexpected token 'DATE"' in NON ADDITIVE BY dimension entry".
# ========================================

statement ok
CREATE SEMANTIC VIEW p68_b1_v1 AS
  TABLES (o AS p68_b1_orders PRIMARY KEY (id))
  DIMENSIONS (o."order date" AS o."order date")
  METRICS (o.qty_sum NON ADDITIVE BY ("order date" DESC) AS SUM(o.qty))

# Query returns rows (snapshot per "order date" — the only-NAB-dim case
# without grouping returns a single snapshot row; DESC selects the earliest
# per F-1, but this test only pins that rows come back, not which snapshot).
query I
SELECT count(*) > 0 FROM semantic_view('p68_b1_v1', metrics := ['qty_sum']);
----
true

# Round-trip: GET_DDL preserves the quoted-whitespace NAB dim verbatim.
# (Renderer expands DESC to "DESC NULLS FIRST" — DESC defaults to NULLS FIRST.)
query I
SELECT GET_DDL('SEMANTIC_VIEW', 'p68_b1_v1') LIKE '%NON ADDITIVE BY ("order date" DESC NULLS FIRST)%';
----
true

# ========================================
# Scenario 2 — dotted path in NAB dim, end-to-end (D-08 + #30)
#
# `o."order date"` is parsed, name-resolved to the dimension whose
# (source_alias, name) is (`o`, `"order date"`), AND — since #30 — expanded
# end-to-end: the snapshot CTE's RANK() OVER ORDER BY now routes the dotted NA
# reference through the shared resolver and emits the resolved dimension
# EXPRESSION (`o."order date"`), not the raw dotted text as a quoted non-column
# (`"o.""order date"""`) that used to fail at bind time.
# ========================================

statement ok
CREATE SEMANTIC VIEW p68_b1_v2 AS
  TABLES (o AS p68_b1_orders PRIMARY KEY (id))
  DIMENSIONS (o."order date" AS o."order date")
  METRICS (o.qty_sum NON ADDITIVE BY (o."order date" DESC) AS SUM(o.qty))

# Round-trip: dotted path preserved in stored DDL (the post-parse + serialise
# + deserialise pipeline carries the dotted form through verbatim).
query I
SELECT GET_DDL('SEMANTIC_VIEW', 'p68_b1_v2') LIKE '%NON ADDITIVE BY (o."order date" DESC NULLS FIRST)%';
----
true

# DESCRIBE confirms the NA dim text is captured verbatim.
query T
SELECT property_value FROM describe_semantic_view('p68_b1_v2') WHERE property = 'NON_ADDITIVE_BY';
----
o."order date" DESC NULLS FIRST

# #30 end-to-end: the dotted-NA metrics-only query expands to a bindable
# snapshot and returns the correct value. Metrics-only ⇒ global snapshot; DESC
# selects the EARLIEST "order date" (2026-01-01, qty 10) per F-1.
query I
SELECT qty_sum FROM semantic_view('p68_b1_v2', metrics := ['qty_sum']);
----
10

# #30: the expanded snapshot CTE orders by the resolved dimension EXPRESSION
# (o."order date"), never the raw dotted text as a quoted non-column.
query I
SELECT count(*) > 0 FROM explain_semantic_view('p68_b1_v2', metrics := ['qty_sum']) WHERE explain_output LIKE '%ORDER BY o."order date"%';
----
true

query I
SELECT count(*) FROM explain_semantic_view('p68_b1_v2', metrics := ['qty_sum']) WHERE explain_output LIKE '%"o.""order date"""%';
----
0

# ========================================
# Scenario 2b — dotted NAB dim that IS queried is effectively regular (#30)
#
# When the dotted NA dim is included in the query, Snowflake semantics make the
# metric effectively additive: standard aggregation, no snapshot CTE.
# ========================================

# One row per "order date" (standard GROUP BY), each with its own qty — proves
# the metric aggregated additively rather than collapsing to a single snapshot.
query I rowsort
SELECT qty_sum FROM semantic_view('p68_b1_v2', dimensions := ['order date'], metrics := ['qty_sum']);
----
10
20

# Effectively-regular ⇒ no RANK snapshot CTE in the expanded plan.
query I
SELECT count(*) FROM explain_semantic_view('p68_b1_v2', dimensions := ['order date'], metrics := ['qty_sum']) WHERE explain_output LIKE '%RANK() OVER%';
----
0

# ========================================
# Scenario 3 — unterminated quoted identifier surfaces a structured error
# Before B1, find_identifier_end would saturate at input.len() and the
# malformed identifier would flow downstream as a "dimension does not match"
# error. Post-B1, is_quoting_balanced surfaces a parser-level error first.
# ========================================

statement error
CREATE SEMANTIC VIEW p68_b1_bad AS
  TABLES (o AS p68_b1_orders PRIMARY KEY (id))
  DIMENSIONS (o."order date" AS o."order date")
  METRICS (o.qty_sum NON ADDITIVE BY ("unclosed DESC) AS SUM(o.qty))
----
Unterminated quoted identifier

# ========================================
# Cleanup
# ========================================

statement ok
DROP SEMANTIC VIEW p68_b1_v1;

statement ok
DROP SEMANTIC VIEW p68_b1_v2;

statement ok
DROP TABLE p68_b1_orders;
