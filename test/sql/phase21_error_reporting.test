# Phase 21: Error location reporting integration tests
# Rewritten for AS-body keyword syntax (CLN-01: paren-body syntax removed).
#
# Verifies error messages flow through DuckDB's parser extension error path
# with character positions (ERR-02) and "did you mean" suggestions (ERR-03).
# Paren-body error tests (bracket validation, clause scanning) are removed --
# those code paths no longer exist.

require semantic_views

# ============================================================
# Section 1: CLN-01 -- Paren-body syntax rejected with clear error
# ============================================================

# Old paren-body syntax produces a clear "no longer supported" error
statement error
CREATE SEMANTIC VIEW err_test (tables := [{'alias': 't', 'table': 't'}], dimensions := [{'name': 'x', 'expr': 'x', 'source_table': 't'}])
----
no longer supported

# Empty parens also rejected (no AS keyword)
statement error
CREATE SEMANTIC VIEW err_test ();
----
no longer supported

# ============================================================
# Section 2: ERR-02 -- Structural errors (missing name, etc.)
# ============================================================

# Missing view name after prefix
statement error
CREATE SEMANTIC VIEW;
----
Missing view name

# Missing view name -- just name keyword with no body
statement error
CREATE SEMANTIC VIEW x
----
Expected 'AS'

# ============================================================
# Section 3: ERR-03 -- "Did you mean" suggestions (near-miss)
# ============================================================

# Typo in DDL prefix: "CREAT" instead of "CREATE"
statement error
CREAT SEMANTIC VIEW test_view AS TABLES (t AS t PRIMARY KEY (id)) DIMENSIONS (t.x AS x) METRICS (t.y AS SUM(1));
----
Did you mean

# Another near-miss: "DROP SEMANTC VIEW" (missing 'I')
statement error
DROP SEMANTC VIEW some_view;
----
Did you mean

# ============================================================
# Section 4: AS-body clause errors
# ============================================================

# Typo in clause keyword -- suggests correct keyword
statement error
CREATE SEMANTIC VIEW err_test AS TABLSE (t AS orders PRIMARY KEY (id)) DIMENSIONS (t.x AS x) METRICS (t.y AS SUM(1));
----
did you mean

# Missing required TABLES clause
statement error
CREATE SEMANTIC VIEW err_test AS DIMENSIONS (t.x AS x) METRICS (t.y AS SUM(1));
----
TABLES

# ============================================================
# Section 5: Non-interference -- normal SQL and valid DDL still work
# ============================================================

# Setup table for valid DDL test
statement ok
CREATE TABLE err_source (id INT, val DOUBLE);

# Valid CREATE still works
statement ok
CREATE SEMANTIC VIEW err_valid AS
TABLES (
    s AS err_source PRIMARY KEY (id)
)
DIMENSIONS (
    s.id AS id
)
METRICS (
    s.total AS SUM(val)
)

# Valid DESCRIBE still works (6 columns: name, base_table, dimensions, metrics, filters, joins)
query TTTTTT
DESCRIBE SEMANTIC VIEW err_valid;
----
err_valid	err_source	[{"expr":"id","name":"id","output_type":null,"source_table":"s"}]	[{"expr":"SUM(val)","name":"total","output_type":null,"source_table":"s"}]	[]	[]

# Normal SQL unaffected
query I
SELECT 42;
----
42

# CREATE OR REPLACE works
statement ok
CREATE OR REPLACE SEMANTIC VIEW err_valid AS
TABLES (
    s AS err_source PRIMARY KEY (id)
)
DIMENSIONS (
    s.id AS id
)
METRICS (
    s.total AS SUM(val)
)

# Tables + metrics only (no dimensions) -- valid
statement ok
CREATE SEMANTIC VIEW err_metrics_only AS
TABLES (
    s AS err_source PRIMARY KEY (id)
)
METRICS (
    s.total AS SUM(val)
)

statement ok
DROP SEMANTIC VIEW err_metrics_only;

# Cleanup
statement ok
DROP SEMANTIC VIEW err_valid;

statement ok
DROP TABLE err_source;
