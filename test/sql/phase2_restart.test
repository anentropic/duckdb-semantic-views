# Phase 10 restart/persistence integration test (PERSIST-01, PERSIST-02).
#
# Verifies that semantic view definitions persist across restart via
# DuckDB-native table storage (semantic_layer._definitions). No companion
# file is involved -- the table is part of the DuckDB WAL and persists
# across restarts automatically.
#
# NOTE: This test is EXCLUDED from test/sql/TEST_LIST (the standard make test
# run) because the Python sqllogictest runner cannot reload an external
# extension after the `restart` directive in a file-backed database: the
# extension's init_catalog SQL runs during LOAD, which may conflict with
# the runner's DB-level lock held during restart.
#
# Restart persistence is verified separately via `cargo test` Rust integration
# tests. When this issue is resolved, re-add this file to TEST_LIST.
#
# Requirements covered:
#   PERSIST-01: definitions persist via DuckDB table (no companion file)
#   PERSIST-02: ROLLBACK reverts definition change in the table

require semantic_views

require notwindows

load __TEST_DIR__/restart_test.db

# Idempotent cleanup: drop any leftover view from a previous run
statement ok
SELECT * FROM drop_semantic_view_if_exists('restart_test');

# Define a view in the file-backed database (PERSIST-01)
statement ok
SELECT * FROM create_semantic_view(
    'restart_test',
    tables := [{'alias': 'e', 'table': 'events'}],
    dimensions := [{'name': 'type', 'expr': 'type', 'source_table': 'e'}],
    metrics := [{'name': 'n', 'expr': 'count(*)', 'source_table': 'e'}]
);

# Verify it is present before restart
query TT rowsort
SELECT name, base_table FROM list_semantic_views();
----
restart_test	events

restart

# After restart the extension is reloaded; init_catalog loads from
# semantic_layer._definitions (DuckDB table, persisted via WAL).
# The view defined before restart must be present.
query TT rowsort
SELECT name, base_table FROM list_semantic_views();
----
restart_test	events

# PERSIST-02: create_semantic_view table function writes via an independent
# persist_conn (separate from the main connection). This means the write to
# semantic_layer._definitions happens outside the caller's transaction scope
# and is NOT rolled back by ROLLBACK on the main connection.
#
# NOTE: The original PRAGMA-based ROLLBACK test (from Phase 10) is no longer
# valid -- PRAGMA define_semantic_view_internal was removed in Phase 11.1 in
# favour of the scalar function DDL interface. Transaction-scoped DDL rollback
# is a known limitation and deferred to a future phase.
#
# Verify that rollback_test is NOT present (it was never defined in this block)
query I
SELECT count(*) FROM list_semantic_views() WHERE name = 'rollback_test';
----
0

# Clean up: drop the restart_test view
statement ok
SELECT * FROM drop_semantic_view('restart_test');

query I
SELECT count(*) FROM list_semantic_views();
----
0
