# Phase 34.1.1: SHOW SEMANTIC LIKE / STARTS WITH / LIMIT filtering
# Tests LIKE, STARTS WITH, and LIMIT clauses on all SHOW SEMANTIC commands.

require semantic_views

# ============================================================
# Setup: create tables and semantic views
# ============================================================

statement ok
CREATE TABLE p3411_customers (id INTEGER PRIMARY KEY, name VARCHAR, region VARCHAR);

statement ok
CREATE TABLE p3411_orders (id INTEGER PRIMARY KEY, customer_id INTEGER, amount DECIMAL(10,2), order_date DATE);

statement ok
CREATE SEMANTIC VIEW filter_sv AS
  TABLES (
    c AS p3411_customers PRIMARY KEY (id),
    o AS p3411_orders PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    orders_to_customers AS o(customer_id) REFERENCES c
  )
  FACTS (
    o.raw_amount AS o.amount
  )
  DIMENSIONS (
    c.customer_name AS c.name,
    c.region AS c.region,
    o.order_date AS o.order_date
  )
  METRICS (
    o.total_amount AS SUM(o.amount),
    o.order_count AS COUNT(o.id)
  )

statement ok
CREATE TABLE p3411_products (id INTEGER PRIMARY KEY, product_name VARCHAR, price DECIMAL(10,2));

statement ok
CREATE SEMANTIC VIEW products_sv AS
  TABLES (
    p AS p3411_products PRIMARY KEY (id)
  )
  DIMENSIONS (
    p.product_name AS p.product_name
  )
  METRICS (
    p.avg_price AS AVG(p.price)
  )

# ============================================================
# Test 1: SHOW SEMANTIC DIMENSIONS LIKE '%name%' (cross-view)
# Matches: customer_name (filter_sv), product_name (products_sv)
# ============================================================

query TTTTT rowsort
SHOW SEMANTIC DIMENSIONS LIKE '%name%'
----
filter_sv	customer_name	c.name	c	(empty)
products_sv	product_name	p.product_name	p	(empty)

# ============================================================
# Test 2: SHOW SEMANTIC DIMENSIONS LIKE '%order%' (cross-view)
# Matches: order_date (filter_sv) only
# ============================================================

query TTTTT rowsort
SHOW SEMANTIC DIMENSIONS LIKE '%order%'
----
filter_sv	order_date	o.order_date	o	(empty)

# ============================================================
# Test 3: SHOW SEMANTIC DIMENSIONS LIKE '%NAME%' IN filter_sv
# Case-insensitive: matches customer_name
# ============================================================

query TTTTT rowsort
SHOW SEMANTIC DIMENSIONS LIKE '%NAME%' IN filter_sv
----
filter_sv	customer_name	c.name	c	(empty)

# ============================================================
# Test 4: SHOW SEMANTIC DIMENSIONS STARTS WITH 'customer' (cross-view)
# Case-sensitive: matches customer_name from filter_sv
# ============================================================

query TTTTT rowsort
SHOW SEMANTIC DIMENSIONS STARTS WITH 'customer'
----
filter_sv	customer_name	c.name	c	(empty)

# ============================================================
# Test 5: SHOW SEMANTIC DIMENSIONS STARTS WITH 'Customer' (cross-view)
# Case-sensitive, wrong case: no matches
# ============================================================

query TTTTT rowsort
SHOW SEMANTIC DIMENSIONS STARTS WITH 'Customer'
----

# ============================================================
# Test 6: SHOW SEMANTIC DIMENSIONS LIKE '%name%' IN filter_sv LIMIT 1
# '%name%' matches only customer_name in filter_sv; LIMIT 1 is deterministic
# ============================================================

query TTTTT rowsort
SHOW SEMANTIC DIMENSIONS LIKE '%name%' IN filter_sv LIMIT 1
----
filter_sv	customer_name	c.name	c	(empty)

# ============================================================
# Test 7: SHOW SEMANTIC METRICS LIKE '%amount%' (cross-view)
# Matches: total_amount from filter_sv
# ============================================================

query TTTTT rowsort
SHOW SEMANTIC METRICS LIKE '%amount%'
----
filter_sv	total_amount	SUM(o.amount)	o	(empty)

# ============================================================
# Test 8: SHOW SEMANTIC METRICS STARTS WITH 'order' (cross-view)
# Matches: order_count from filter_sv
# ============================================================

query TTTTT rowsort
SHOW SEMANTIC METRICS STARTS WITH 'order'
----
filter_sv	order_count	COUNT(o.id)	o	(empty)

# ============================================================
# Test 9: SHOW SEMANTIC FACTS LIKE '%amount%' (cross-view)
# Matches: raw_amount from filter_sv
# ============================================================

query TTTT rowsort
SHOW SEMANTIC FACTS LIKE '%amount%'
----
filter_sv	raw_amount	o.amount	o

# ============================================================
# Test 10: SHOW SEMANTIC FACTS STARTS WITH 'raw' (cross-view)
# Matches: raw_amount from filter_sv
# ============================================================

query TTTT rowsort
SHOW SEMANTIC FACTS STARTS WITH 'raw'
----
filter_sv	raw_amount	o.amount	o

# ============================================================
# Test 11: SHOW SEMANTIC FACTS IN filter_sv LIMIT 1
# filter_sv has 1 fact; LIMIT 1 returns that one
# ============================================================

query TTTT
SHOW SEMANTIC FACTS IN filter_sv LIMIT 1
----
filter_sv	raw_amount	o.amount	o

# ============================================================
# Test 12: Composition: LIKE + IN + STARTS WITH + LIMIT
# LIKE '%name%' matches customer_name, STARTS WITH 'cust' also matches
# ============================================================

query TTTTT rowsort
SHOW SEMANTIC DIMENSIONS LIKE '%name%' IN filter_sv STARTS WITH 'cust' LIMIT 10
----
filter_sv	customer_name	c.name	c	(empty)

# ============================================================
# Test 13: FOR METRIC with LIKE
# total_amount (source: o): safe dims = customer_name, region, order_date (all safe)
# LIKE '%gio%' matches only region
# ============================================================

query TTTTT rowsort
SHOW SEMANTIC DIMENSIONS LIKE '%gio%' IN filter_sv FOR METRIC total_amount
----
filter_sv	region	c.region	c	(empty)

# ============================================================
# Test 14: FOR METRIC with STARTS WITH
# total_amount safe dims: customer_name, region
# STARTS WITH 'customer' matches customer_name
# ============================================================

query TTTTT rowsort
SHOW SEMANTIC DIMENSIONS IN filter_sv FOR METRIC total_amount STARTS WITH 'customer'
----
filter_sv	customer_name	c.name	c	(empty)

# ============================================================
# Test 15: FOR METRIC with LIMIT
# total_amount safe dims: customer_name, region, order_date (3 dims, all safe)
# LIMIT 3 returns all (deterministic since there are exactly 3)
# ============================================================

query TTTTT rowsort
SHOW SEMANTIC DIMENSIONS IN filter_sv FOR METRIC total_amount LIMIT 3
----
filter_sv	customer_name	c.name	c	(empty)
filter_sv	order_date	o.order_date	o	(empty)
filter_sv	region	c.region	c	(empty)

# ============================================================
# Test 16: Error: wrong clause order (LIKE after IN)
# ============================================================

statement error
SHOW SEMANTIC DIMENSIONS IN filter_sv LIKE '%x%'
----
Unexpected tokens

# ============================================================
# Test 17: Case insensitivity of keywords
# ============================================================

query TTTTT rowsort
show semantic dimensions like '%name%' in filter_sv
----
filter_sv	customer_name	c.name	c	(empty)

# ============================================================
# Test 18: Empty LIKE pattern (matches nothing)
# ============================================================

query TTTTT rowsort
SHOW SEMANTIC DIMENSIONS LIKE '' IN filter_sv
----

# ============================================================
# Test 19: SHOW SEMANTIC VIEWS LIKE '%filter%' -- matches filter_sv only
# ============================================================

query TT rowsort
SHOW SEMANTIC VIEWS LIKE '%filter%'
----
filter_sv	p3411_customers

# ============================================================
# Test 20: SHOW SEMANTIC VIEWS LIKE '%sv' -- matches both (both end in _sv)
# ============================================================

query TT rowsort
SHOW SEMANTIC VIEWS LIKE '%sv'
----
filter_sv	p3411_customers
products_sv	p3411_products

# ============================================================
# Test 21: SHOW SEMANTIC VIEWS STARTS WITH 'filter' -- case-sensitive match
# ============================================================

query TT rowsort
SHOW SEMANTIC VIEWS STARTS WITH 'filter'
----
filter_sv	p3411_customers

# ============================================================
# Test 22: SHOW SEMANTIC VIEWS STARTS WITH 'Filter' -- wrong case, no match
# ============================================================

query TT rowsort
SHOW SEMANTIC VIEWS STARTS WITH 'Filter'
----

# ============================================================
# Test 23: SHOW SEMANTIC VIEWS LIMIT 1 -- returns exactly 1 row
# ============================================================

query TT
SHOW SEMANTIC VIEWS LIMIT 1
----
filter_sv	p3411_customers

# ============================================================
# Test 24: SHOW SEMANTIC VIEWS LIKE '%sv' LIMIT 1 -- both match, limited to 1
# ============================================================

query TT
SHOW SEMANTIC VIEWS LIKE '%sv' LIMIT 1
----
filter_sv	p3411_customers

# ============================================================
# Test 25: SHOW SEMANTIC VIEWS LIKE '%sv' STARTS WITH 'prod' LIMIT 10
# Only products_sv matches both conditions
# ============================================================

query TT rowsort
SHOW SEMANTIC VIEWS LIKE '%sv' STARTS WITH 'prod' LIMIT 10
----
products_sv	p3411_products

# ============================================================
# Test 26: Error: SHOW SEMANTIC VIEWS IN some_view
# ============================================================

statement error
SHOW SEMANTIC VIEWS IN some_view
----
IN is not valid

# ============================================================
# Test 27: Error: SHOW SEMANTIC VIEWS FOR METRIC m
# ============================================================

statement error
SHOW SEMANTIC VIEWS FOR METRIC m
----
FOR METRIC is only valid

# ============================================================
# Cleanup
# ============================================================

statement ok
DROP SEMANTIC VIEW filter_sv

statement ok
DROP SEMANTIC VIEW products_sv

statement ok
DROP TABLE p3411_orders

statement ok
DROP TABLE p3411_customers

statement ok
DROP TABLE p3411_products
