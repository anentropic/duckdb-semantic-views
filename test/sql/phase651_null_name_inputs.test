# Phase 65.1 Plan 09 (IN-05, D-25) — null name vector input handling for
# scalar functions accepting a view-name argument.
#
# Each scalar function takes a view name (or related lookup key) as a
# VARCHAR argument. When the argument is NULL the function MUST short-
# circuit to NULL rather than raise or treat the literal string "NULL"
# as a lookup key.

require semantic_views

statement ok
LOAD semantic_views;

# --- read_yaml_from_semantic_view: single name argument --------------------

query I
SELECT read_yaml_from_semantic_view(NULL) IS NULL
----
true

# --- get_ddl: (object_type, object_name) - either arg NULL → NULL ----------

query I
SELECT get_ddl(NULL, 'x') IS NULL
----
true

query I
SELECT get_ddl('SEMANTIC_VIEW', NULL) IS NULL
----
true
