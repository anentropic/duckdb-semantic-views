# PEG parser compatibility smoke test for DuckDB 1.5.0+.
#
# DuckDB 1.5.0 introduced an opt-in PEG parser (CALL enable_peg_parser()).
#
# v0.8.1 collapsed all DDL onto the parser_override hook. parser_override is
# registered on ParserExtension and called BEFORE the active parser; the hook
# returns native SQL that the live parser then parses. Because the synthesised
# SQL (INSERT/DELETE/UPDATE on _definitions for write-side, SELECT * FROM
# read-side table function for DESCRIBE/SHOW/GET_DDL/READ_YAML) only uses
# vanilla SQL constructs, every form works under Bison and PEG identically.
#
# The legacy `parse_function` Bison-only fallback is gone (deleted in the
# v0.8.1 architectural unification). DESCRIBE / SHOW used to require Bison;
# v0.8.1 makes them parser-agnostic.
#
# This test documents the expected behavior:
#   1. All DDL works under the default Bison parser
#   2. Under PEG: every DDL form (CREATE / DROP / ALTER / DESCRIBE / SHOW /
#      FROM YAML FILE) works — parser_override fires first
#   3. Querying existing views works under PEG (semantic_view() is a table function)
#   4. All DDL works again after disabling PEG parser
#
# Requirements covered:
#   DKDB-05: PEG parser compatibility documented

require semantic_views

# ============================================================
# 1. Setup -- create test data
# ============================================================

statement ok
CREATE TABLE peg_test_data (id INTEGER, val DOUBLE);

statement ok
INSERT INTO peg_test_data VALUES (1, 10.0), (2, 20.0);

# ============================================================
# 2. Bison parser (default): DDL and query work
# ============================================================

statement ok
CREATE SEMANTIC VIEW peg_bison_test AS
TABLES (t AS peg_test_data PRIMARY KEY (id))
DIMENSIONS (t.dim_id AS t.id)
METRICS (t.total_val AS SUM(t.val))

query IR
SELECT * FROM semantic_view('peg_bison_test', dimensions := ['dim_id'], metrics := ['total_val']) ORDER BY dim_id;
----
1	10.0
2	20.0

# ============================================================
# 3. Enable PEG parser: every DDL form works via parser_override.
# ============================================================

statement ok
CALL enable_peg_parser();

# CREATE goes through parser_override (parser-agnostic) — works under PEG.
statement ok
CREATE SEMANTIC VIEW peg_under_peg AS
TABLES (t2 AS peg_test_data PRIMARY KEY (id))
DIMENSIONS (t2.dim_id AS t2.id)
METRICS (t2.total_val AS SUM(t2.val))

# DROP also goes through parser_override.
statement ok
DROP SEMANTIC VIEW peg_under_peg

# CREATE ... FROM YAML FILE also goes through parser_override (v0.8.0+):
# the __SV_YAML_FILE__ sentinel is intercepted in parser_override, the file
# is read on the catalog connection, and the resulting INSERT is routed
# through the same native-SQL re-parse path as inline CREATE.
statement ok
COPY (SELECT 'tables:
  - alias: t4
    table: peg_test_data
    pk_columns:
      - id
dimensions:
  - name: dim_id
    expr: t4.id
    source_table: t4
metrics:
  - name: total_val
    expr: SUM(t4.val)
    source_table: t4' AS content)
TO '__TEST_DIR__/peg_yaml_file.yaml' (FORMAT CSV, HEADER FALSE, QUOTE '');

statement ok
CREATE SEMANTIC VIEW peg_yaml_file FROM YAML FILE '__TEST_DIR__/peg_yaml_file.yaml'

statement ok
DROP SEMANTIC VIEW peg_yaml_file

# DESCRIBE / SHOW now go through parser_override (v0.8.1 unification) and
# work under PEG. parser_override emits a `SELECT * FROM <read_side_fn>(...)`
# pass-through that the PEG parser parses fine. Asserted via `statement ok`
# because the row content is covered elsewhere; what matters here is that
# the parse succeeds under PEG.
statement ok
DESCRIBE SEMANTIC VIEW peg_bison_test

statement ok
SHOW SEMANTIC VIEWS

statement ok
SHOW SEMANTIC METRICS

# Querying existing views works: semantic_view() is a standard table function.
query IR
SELECT * FROM semantic_view('peg_bison_test', dimensions := ['dim_id'], metrics := ['total_val']) ORDER BY dim_id;
----
1	10.0
2	20.0

# ============================================================
# 4. Disable PEG parser: DDL works again
# ============================================================
#
# Caveat: DuckDB's `CALL disable_peg_parser()` resets
# `allow_parser_override_extension` to its default (`default`), which silently
# bypasses parser_override hooks. The extension installs `FALLBACK` on load,
# so a process that never enables PEG never hits this. Tests that toggle PEG
# must restore FALLBACK explicitly. Documented in MAINTAINER.md.

statement ok
CALL disable_peg_parser();

# B8 (Phase 62) — disable_peg_parser silently resets
# allow_parser_override_extension to DEFAULT. Without re-arming FALLBACK,
# parser_override does NOT fire on this connection; the default parser
# fails on the unrecognised CREATE SEMANTIC VIEW prefix; DuckDB calls
# our parse_function which sees a well-formed semantic-view DDL and
# emits the actionable rc=3 hint with caret.
statement error
CREATE SEMANTIC VIEW peg_b8_unprivileged AS
TABLES (t8 AS peg_test_data PRIMARY KEY (id))
DIMENSIONS (t8.dim_id AS t8.id)
METRICS (t8.total_val AS SUM(t8.val))
----
SET allow_parser_override_extension='FALLBACK'

# Recovery: re-arm FALLBACK and CREATE succeeds.
statement ok
SET allow_parser_override_extension='FALLBACK';

statement ok
CREATE SEMANTIC VIEW peg_restored_test AS
TABLES (t3 AS peg_test_data PRIMARY KEY (id))
DIMENSIONS (t3.dim_id AS t3.id)
METRICS (t3.total_val AS SUM(t3.val))

query IR
SELECT * FROM semantic_view('peg_restored_test', dimensions := ['dim_id'], metrics := ['total_val']) ORDER BY dim_id;
----
1	10.0
2	20.0

# DESCRIBE works again with Bison.
statement ok
DESCRIBE SEMANTIC VIEW peg_bison_test

# ============================================================
# 5. Cleanup
# ============================================================

statement ok
DROP SEMANTIC VIEW peg_bison_test;

statement ok
DROP SEMANTIC VIEW peg_restored_test;

statement ok
DROP TABLE peg_test_data;
