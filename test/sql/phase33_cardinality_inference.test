# ============================================================
# Test 10 (CARD-07): REFERENCES target with no PK on target -> error
# ============================================================

statement error
CREATE SEMANTIC VIEW p33_no_pk_target AS
  TABLES (
    f AS p33_line_items,
    o AS p33_orders
  )
  RELATIONSHIPS (
    li_to_order AS f(order_id) REFERENCES o
  )
  DIMENSIONS (
    f.status AS f.status
  )
  METRICS (
    f.revenue AS SUM(f.price)
  );
----
has no PRIMARY KEY

# ============================================================
# Test 11 (CARD-08): Fan trap with inferred cardinality -- chain
# li->o->c all ManyToOne. Metric from c, dim from li via o reverse = fan-out
# ============================================================

statement ok
CREATE SEMANTIC VIEW p33_chain AS
  TABLES (
    o AS p33_orders PRIMARY KEY (id),
    li AS p33_line_items PRIMARY KEY (id),
    c AS p33_customers PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    li_to_order AS li(order_id) REFERENCES o,
    order_to_customer AS o(customer_id) REFERENCES c
  )
  DIMENSIONS (
    c.name AS c.name,
    li.status AS li.status
  )
  METRICS (
    li.revenue AS SUM(li.price),
    c.cust_count AS COUNT(*)
  );

# Safe: li->o->c is ManyToOne chain
query TR rowsort
SELECT * FROM semantic_view('p33_chain', dimensions := ['name'], metrics := ['revenue']);
----
Alice	150.0
Bob	200.0

# Fan trap: c->o->li requires reverse traversal of ManyToOne edges
statement error
SELECT * FROM semantic_view('p33_chain', dimensions := ['status'], metrics := ['cust_count']);
----
fan trap detected

statement ok
DROP SEMANTIC VIEW p33_chain;

