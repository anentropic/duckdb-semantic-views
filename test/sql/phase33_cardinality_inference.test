# ============================================================
# Test 13: DESCRIBE shows UNIQUE and inferred cardinality
# ============================================================

statement ok
CREATE SEMANTIC VIEW p33_describe AS
  TABLES (
    c AS p33_customers PRIMARY KEY (id) UNIQUE (email),
    o AS p33_orders PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    order_to_customer AS o(customer_id) REFERENCES c
  )
  DIMENSIONS (
    c.name AS c.name
  )
  METRICS (
    o.revenue AS SUM(o.amount)
  );

# DESCRIBE should not error and should return one row
query I
SELECT COUNT(*) FROM describe_semantic_view('p33_describe');
----
1

statement ok
DROP SEMANTIC VIEW p33_describe;

