# Phase 33: End-to-end test for UNIQUE constraints and cardinality inference
# Tests CARD-01 through CARD-09: UNIQUE parsing, cardinality inference,
# FK/PK/UNIQUE validation, fan trap with inferred cardinality, DESCRIBE output.

require semantic_views

# ============================================================
# Setup: physical tables
# ============================================================

statement ok
CREATE TABLE p33_customers (id INTEGER, email VARCHAR, name VARCHAR);

statement ok
INSERT INTO p33_customers VALUES (1, 'alice@test.com', 'Alice'), (2, 'bob@test.com', 'Bob');

statement ok
CREATE TABLE p33_orders (id INTEGER, customer_id INTEGER, region VARCHAR, amount DOUBLE);

statement ok
INSERT INTO p33_orders VALUES (1, 1, 'East', 100.0), (2, 2, 'West', 200.0), (3, 1, 'East', 50.0);

statement ok
CREATE TABLE p33_line_items (id INTEGER, order_id INTEGER, price DOUBLE, status VARCHAR);

statement ok
INSERT INTO p33_line_items VALUES (1, 1, 40.0, 'shipped'), (2, 1, 60.0, 'pending'), (3, 2, 200.0, 'shipped'), (4, 3, 50.0, 'shipped');

statement ok
CREATE TABLE p33_profiles (user_id INTEGER, bio VARCHAR);

statement ok
INSERT INTO p33_profiles VALUES (1, 'Engineer'), (2, 'Designer');

# ============================================================
# Test 1 (CARD-01, CARD-02): UNIQUE constraints in TABLES clause
# ============================================================

statement ok
CREATE SEMANTIC VIEW p33_basic AS
  TABLES (
    c AS p33_customers PRIMARY KEY (id) UNIQUE (email),
    o AS p33_orders PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    order_to_customer AS o(customer_id) REFERENCES c
  )
  DIMENSIONS (
    c.name AS c.name
  )
  METRICS (
    o.revenue AS SUM(o.amount)
  );

query TR rowsort
SELECT * FROM semantic_view('p33_basic', dimensions := ['name'], metrics := ['revenue']);
----
Alice	150.0
Bob	200.0

statement ok
DROP SEMANTIC VIEW p33_basic;

# ============================================================
# Test 2 (CARD-02): Multiple UNIQUE constraints on one table
# ============================================================

statement ok
CREATE SEMANTIC VIEW p33_multi_unique AS
  TABLES (
    c AS p33_customers PRIMARY KEY (id) UNIQUE (email) UNIQUE (name),
    o AS p33_orders PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    order_to_customer AS o(customer_id) REFERENCES c
  )
  DIMENSIONS (
    c.name AS c.name
  )
  METRICS (
    o.revenue AS SUM(o.amount)
  );

query TR rowsort
SELECT * FROM semantic_view('p33_multi_unique', dimensions := ['name'], metrics := ['revenue']);
----
Alice	150.0
Bob	200.0

statement ok
DROP SEMANTIC VIEW p33_multi_unique;

# ============================================================
# Test 3 (CARD-03): FK must reference PK or UNIQUE on target -- error
# ============================================================

statement error
CREATE SEMANTIC VIEW p33_bad_ref AS
  TABLES (
    c AS p33_customers PRIMARY KEY (id) UNIQUE (email),
    o AS p33_orders PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    order_to_customer AS o(customer_id) REFERENCES c(name)
  )
  DIMENSIONS (
    c.name AS c.name
  )
  METRICS (
    o.revenue AS SUM(o.amount)
  );
----
does not match any PRIMARY KEY or UNIQUE constraint

# ============================================================
# Test 4 (CARD-04): Cardinality inferred -- ManyToOne (bare FK)
# Fan trap: metric from o, dim from li -- o->li is reverse ManyToOne = fan-out
# ============================================================

statement ok
CREATE SEMANTIC VIEW p33_infer_many AS
  TABLES (
    o AS p33_orders PRIMARY KEY (id),
    li AS p33_line_items PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    li_to_order AS li(order_id) REFERENCES o
  )
  DIMENSIONS (
    o.region AS o.region,
    li.status AS li.status
  )
  METRICS (
    li.revenue AS SUM(li.price),
    o.order_count AS COUNT(*)
  );

# Safe: li->o forward ManyToOne
query TR rowsort
SELECT * FROM semantic_view('p33_infer_many', dimensions := ['region'], metrics := ['revenue']);
----
East	150.0
West	200.0

# Fan trap: o->li reverse ManyToOne = fan-out
statement error
SELECT * FROM semantic_view('p33_infer_many', dimensions := ['status'], metrics := ['order_count']);
----
fan trap detected

statement ok
DROP SEMANTIC VIEW p33_infer_many;

# ============================================================
# Test 5 (CARD-04): OneToOne inferred -- FK matches PK on from-side
# ============================================================

statement ok
CREATE SEMANTIC VIEW p33_infer_oto AS
  TABLES (
    c AS p33_customers PRIMARY KEY (id),
    p AS p33_profiles PRIMARY KEY (user_id)
  )
  RELATIONSHIPS (
    customer_profile AS c(id) REFERENCES p(user_id)
  )
  DIMENSIONS (
    c.name AS c.name,
    p.bio AS p.bio
  )
  METRICS (
    c.customer_count AS COUNT(*),
    p.profile_count AS COUNT(*)
  );

# OneToOne: both directions safe
query TI rowsort
SELECT * FROM semantic_view('p33_infer_oto', dimensions := ['bio'], metrics := ['customer_count']);
----
Designer	1
Engineer	1

query TI rowsort
SELECT * FROM semantic_view('p33_infer_oto', dimensions := ['name'], metrics := ['profile_count']);
----
Alice	1
Bob	1

statement ok
DROP SEMANTIC VIEW p33_infer_oto;

# ============================================================
# Test 6 (CARD-04): OneToOne from UNIQUE match on from-side
# Uses a UNIQUE constraint (not PK) that the FK column matches.
# ============================================================

statement ok
CREATE TABLE p33_user_tokens (token_id INTEGER, user_id INTEGER, token VARCHAR);

statement ok
INSERT INTO p33_user_tokens VALUES (1, 1, 'tok_a'), (2, 2, 'tok_b');

statement ok
CREATE SEMANTIC VIEW p33_infer_oto_unique AS
  TABLES (
    t AS p33_user_tokens PRIMARY KEY (token_id) UNIQUE (user_id),
    c AS p33_customers PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    token_to_customer AS t(user_id) REFERENCES c
  )
  DIMENSIONS (
    c.name AS c.name,
    t.token AS t.token
  )
  METRICS (
    c.customer_count AS COUNT(*)
  );

# user_id is UNIQUE on t -> OneToOne, both directions safe
query TI rowsort
SELECT * FROM semantic_view('p33_infer_oto_unique', dimensions := ['token'], metrics := ['customer_count']);
----
tok_a	1
tok_b	1

statement ok
DROP SEMANTIC VIEW p33_infer_oto_unique;

statement ok
DROP TABLE p33_user_tokens;

# ============================================================
# Test 7 (CARD-05): Explicit cardinality keywords rejected
# ============================================================

statement error
CREATE SEMANTIC VIEW p33_explicit_card AS
  TABLES (
    o AS p33_orders PRIMARY KEY (id),
    li AS p33_line_items PRIMARY KEY (id)
  )
  RELATIONSHIPS (
    li_to_order AS li(order_id) REFERENCES o MANY TO ONE
  )
  DIMENSIONS (
    o.region AS o.region
  )
  METRICS (
    li.revenue AS SUM(li.price)
  );
----
no longer supported

