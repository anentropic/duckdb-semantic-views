# Phase 25: SQL keyword body parser integration tests
# Tests for CREATE SEMANTIC VIEW ... AS TABLES (...) RELATIONSHIPS (...) DIMENSIONS (...) METRICS (...)

require semantic_views

# Setup: minimal test tables with data
statement ok
CREATE TABLE p25_orders (o_orderkey INTEGER, o_custkey INTEGER, revenue DOUBLE, region VARCHAR);

statement ok
INSERT INTO p25_orders VALUES (1, 10, 100.0, 'East'), (2, 20, 200.0, 'West');

statement ok
CREATE TABLE p25_customers (c_custkey INTEGER, c_name VARCHAR);

statement ok
INSERT INTO p25_customers VALUES (10, 'Alice'), (20, 'Bob');

# DDL-01: CREATE SEMANTIC VIEW with keyword body (single table, no relationships)
statement ok
CREATE SEMANTIC VIEW p25_orders_view AS
TABLES (
    o AS p25_orders PRIMARY KEY (o_orderkey)
)
DIMENSIONS (
    o.region AS region
)
METRICS (
    o.total_revenue AS SUM(revenue)
)

# DDL-01: Query the created view to confirm it works end-to-end
query TT rowsort
SELECT region, total_revenue FROM semantic_view('p25_orders_view', dimensions := ['region'], metrics := ['total_revenue'])
----
East	100.0
West	200.0

# DDL-07: CREATE OR REPLACE works with keyword body
statement ok
CREATE OR REPLACE SEMANTIC VIEW p25_orders_view AS
TABLES (
    o AS p25_orders PRIMARY KEY (o_orderkey)
)
DIMENSIONS (
    o.region AS region
)
METRICS (
    o.total_revenue AS SUM(revenue)
)

# DDL-07: CREATE IF NOT EXISTS works with keyword body (no-op on existing view)
statement ok
CREATE SEMANTIC VIEW IF NOT EXISTS p25_orders_view AS
TABLES (
    o AS p25_orders PRIMARY KEY (o_orderkey)
)
DIMENSIONS (
    o.region AS region
)
METRICS (
    o.total_revenue AS SUM(revenue)
)

# DDL-07: Multi-table view with RELATIONSHIPS clause
statement ok
CREATE SEMANTIC VIEW p25_oc_view AS
TABLES (
    o AS p25_orders PRIMARY KEY (o_orderkey),
    c AS p25_customers PRIMARY KEY (c_custkey)
)
RELATIONSHIPS (
    order_to_customer AS o(o_custkey) REFERENCES c
)
DIMENSIONS (
    o.region AS region,
    c.c_name AS customer_name
)
METRICS (
    o.total_revenue AS SUM(revenue)
)

# DDL-07: DESCRIBE works -- returns 5 VARCHAR columns (property-per-row)
query TTTTT
DESCRIBE SEMANTIC VIEW p25_orders_view
----
TABLE	p25_orders	(empty)	BASE_TABLE_DATABASE_NAME	memory
TABLE	p25_orders	(empty)	BASE_TABLE_SCHEMA_NAME	main
TABLE	p25_orders	(empty)	BASE_TABLE_NAME	p25_orders
TABLE	p25_orders	(empty)	PRIMARY_KEY	["o_orderkey"]
DIMENSION	region	p25_orders	TABLE	p25_orders
DIMENSION	region	p25_orders	EXPRESSION	region
DIMENSION	region	p25_orders	DATA_TYPE	(empty)
METRIC	total_revenue	p25_orders	TABLE	p25_orders
METRIC	total_revenue	p25_orders	EXPRESSION	SUM(revenue)
METRIC	total_revenue	p25_orders	DATA_TYPE	(empty)
METRIC	total_revenue	p25_orders	ACCESS_MODIFIER	PUBLIC

# DDL-07: SHOW works -- returns view name and kind for all current views
query TT rowsort
SELECT name, kind FROM list_semantic_views()
----
p25_oc_view	SEMANTIC_VIEW
p25_orders_view	SEMANTIC_VIEW

# DDL-07: DROP works
statement ok
DROP SEMANTIC VIEW p25_oc_view

# DDL-07: DROP IF EXISTS works (view already dropped -- should succeed silently)
statement ok
DROP SEMANTIC VIEW IF EXISTS p25_oc_view

# Error: TABLES clause is required
statement error
CREATE SEMANTIC VIEW p25_bad_view AS
DIMENSIONS (
    o.region AS region
)
METRICS (
    o.revenue AS SUM(revenue)
)
----
TABLES

# Error: DIMENSIONS or METRICS is required
statement error
CREATE SEMANTIC VIEW p25_bad_view2 AS
TABLES (
    o AS p25_orders PRIMARY KEY (o_orderkey)
)
----
DIMENSIONS

# Cleanup
statement ok
DROP SEMANTIC VIEW IF EXISTS p25_orders_view

statement ok
DROP TABLE p25_orders

statement ok
DROP TABLE p25_customers
