# ============================================================
# Scenario A1.7 — Window metric × non-default schema (PREPEND)
# (src/expand/window.rs:156, 181, 199)
# ============================================================

statement ok
USE memory.p67_win;

statement ok
CREATE TABLE sales (
    id INTEGER PRIMARY KEY,
    store VARCHAR,
    sale_date DATE,
    quantity INTEGER
);

statement ok
INSERT INTO sales VALUES
    (1, 'NYC', '2024-01-01', 10),
    (2, 'NYC', '2024-01-02', 20),
    (3, 'LA',  '2024-01-01', 5);

statement ok
CREATE SEMANTIC VIEW p67_win_sch AS
TABLES (s AS sales PRIMARY KEY (id))
DIMENSIONS (
    s.store AS s.store,
    s.sale_date AS s.sale_date
)
METRICS (
    PRIVATE s.total_qty AS SUM(s.quantity),
    s.avg_qty AS AVG(total_qty) OVER (PARTITION BY EXCLUDING sale_date ORDER BY sale_date ASC NULLS LAST)
);

statement ok
USE memory.main;

query I
SELECT count(*) > 0 FROM explain_semantic_view('p67_win.p67_win_sch', dimensions := ['store', 'sale_date'], metrics := ['avg_qty']) WHERE explain_output LIKE '%OVER (PARTITION BY%';
----
true

query I
SELECT count(*) > 0 FROM explain_semantic_view('p67_win.p67_win_sch', dimensions := ['store', 'sale_date'], metrics := ['avg_qty']) WHERE explain_output LIKE '%FROM "memory"."p67_win"."sales"%';
----
true

query I
SELECT count(*) > 0 FROM semantic_view('p67_win.p67_win_sch', dimensions := ['store', 'sale_date'], metrics := ['avg_qty']);
----
true

