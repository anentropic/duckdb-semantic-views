# ============================================================
# Scenario A1.9 — Materialization routing × non-default schema (PREPEND)
# Two assertions:
#  - Routing hit emits qualified FROM to the materialization target
#    (src/expand/materialization.rs:163)
#  - Routing miss falls back to raw expansion which emits qualified
#    FROM to the base table (src/expand/sql_gen.rs:497)
# ============================================================

statement ok
USE memory.p67_mat;

statement ok
CREATE TABLE orders (id INTEGER PRIMARY KEY, region VARCHAR, status VARCHAR, amount DECIMAL(10,2));

statement ok
INSERT INTO orders VALUES
    (1, 'US', 'shipped', 100.00),
    (2, 'EU', 'pending', 200.00);

statement ok
CREATE TABLE agg_region (region VARCHAR, total_revenue DECIMAL(10,2));

statement ok
INSERT INTO agg_region VALUES ('US', 100.00), ('EU', 200.00);

statement ok
CREATE SEMANTIC VIEW p67_mat_sch AS
TABLES (
    o AS orders PRIMARY KEY (id)
)
DIMENSIONS (
    o.region AS o.region,
    o.status AS o.status
)
METRICS (
    o.total_revenue AS SUM(o.amount)
)
MATERIALIZATIONS (
    region_agg AS (
        TABLE agg_region,
        DIMENSIONS (region),
        METRICS (total_revenue)
    )
);

statement ok
USE memory.main;

# Routing hit (region/total_revenue match the materialization)
query I
SELECT count(*) > 0 FROM explain_semantic_view('p67_mat.p67_mat_sch', dimensions := ['region'], metrics := ['total_revenue']) WHERE explain_output LIKE '%FROM "memory"."p67_mat"."agg_region"%';
----
true

query I
SELECT count(*) > 0 FROM semantic_view('p67_mat.p67_mat_sch', dimensions := ['region'], metrics := ['total_revenue']);
----
true

# Routing miss (status dim not covered → raw expand on base table)
query I
SELECT count(*) > 0 FROM explain_semantic_view('p67_mat.p67_mat_sch', dimensions := ['region', 'status'], metrics := ['total_revenue']) WHERE explain_output LIKE '%FROM "memory"."p67_mat"."orders"%';
----
true

query I
SELECT count(*) > 0 FROM semantic_view('p67_mat.p67_mat_sch', dimensions := ['region', 'status'], metrics := ['total_revenue']);
----
true

# ============================================================
# Scenario A1.10 — Materialization routing × ATTACHed DB (PASS-THROUGH)
# ============================================================

statement ok
ATTACH ':memory:' AS db2;

statement ok
CREATE TABLE db2.main.orders_mat (id INTEGER PRIMARY KEY, region VARCHAR, status VARCHAR, amount DECIMAL(10,2));

statement ok
INSERT INTO db2.main.orders_mat VALUES (1, 'US', 'shipped', 100.00);

statement ok
CREATE TABLE db2.main.agg_region_mat (region VARCHAR, total_revenue DECIMAL(10,2));

statement ok
INSERT INTO db2.main.agg_region_mat VALUES ('US', 100.00);

statement ok
CREATE SEMANTIC VIEW p67_mat_db2 AS
TABLES (
    o AS db2.main.orders_mat PRIMARY KEY (id)
)
DIMENSIONS (
    o.region AS o.region,
    o.status AS o.status
)
METRICS (
    o.total_revenue AS SUM(o.amount)
)
MATERIALIZATIONS (
    region_agg AS (
        TABLE db2.main.agg_region_mat,
        DIMENSIONS (region),
        METRICS (total_revenue)
    )
);

# Routing hit
query I
SELECT count(*) > 0 FROM explain_semantic_view('p67_mat_db2', dimensions := ['region'], metrics := ['total_revenue']) WHERE explain_output LIKE '%FROM "db2"."main"."agg_region_mat"%';
----
true

query I
SELECT count(*) > 0 FROM semantic_view('p67_mat_db2', dimensions := ['region'], metrics := ['total_revenue']);
----
true

# Routing miss → base table
query I
SELECT count(*) > 0 FROM explain_semantic_view('p67_mat_db2', dimensions := ['region', 'status'], metrics := ['total_revenue']) WHERE explain_output LIKE '%FROM "db2"."main"."orders_mat"%';
----
true

query I
SELECT count(*) > 0 FROM semantic_view('p67_mat_db2', dimensions := ['region', 'status'], metrics := ['total_revenue']);
----
true

statement ok
DROP SEMANTIC VIEW p67_mat_db2;

statement ok
DETACH db2;

