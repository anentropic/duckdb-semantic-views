# ============================================================

statement error
CREATE SEMANTIC VIEW p30_count_agg AS
  TABLES (
    o AS p30_orders PRIMARY KEY (id)
  )
  DIMENSIONS (
    o.region AS o.region
  )
  METRICS (
    o.revenue AS SUM(o.id),
    bad AS COUNT(revenue)
  );
----
must not contain aggregate function

statement error
CREATE SEMANTIC VIEW p30_avg_agg AS
  TABLES (
    o AS p30_orders PRIMARY KEY (id)
  )
  DIMENSIONS (
    o.region AS o.region
  )
  METRICS (
    o.revenue AS SUM(o.id),
    bad AS AVG(revenue)
  );
----
must not contain aggregate function

# ============================================================
# Cleanup
# ============================================================

statement ok
DROP SEMANTIC VIEW p30_sales_facts;

statement ok
DROP TABLE p30_line_items;

statement ok
DROP TABLE p30_orders;
