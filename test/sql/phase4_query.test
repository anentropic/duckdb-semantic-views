# Phase 4 query round-trip integration tests.
# Updated for keyword args: uses create_semantic_view with named params
# and typed output columns (BIGINT metrics use query I, DATE time dimensions use query D).
#
# Exercises semantic_view table function against real DuckDB tables with known
# data. Covers basic aggregation, WHERE composition, multi-table joins,
# EXPLAIN plan equivalence, dimensions-only, metrics-only, and error cases.
#
# NOTE: DECIMAL columns (e.g., sum(amount)) continue to return VARCHAR for
# exact precision formatting. INTEGER/BIGINT count metrics return typed I.
# DATE time dimensions return typed D.
#
# NOTE: The CTE architecture (WITH "_base" AS (SELECT * ...)) flattens all
# joined tables. Dimension and metric expressions must use UNQUALIFIED column
# names (e.g., 'region' not 'o.region'). Table alias qualification applies
# only to join ON clause generation (via join_columns) and source_table field
# (for join resolution). This is consistent with the original semantic view design.
#
# Requirements covered:
#   TEST-03: Integration tests load the extension, create semantic views, run
#            real DuckDB SQL queries, and assert correct results
#   QUERY-01: semantic_view with named array parameters returns correct results
#   QUERY-02: User WHERE clauses compose with view filters
#   QUERY-03: SELECT * returns all requested dimensions and metrics
#   DDL-04: 6-arg STRUCT/LIST DDL interface
#   DDL-06: semantic_view function name (renamed from semantic_query)
#   EXPL-01: explain_semantic_view returns expanded SQL
#   OUT-01: semantic_view returns typed columns (BIGINT, DATE) for numeric/date data
#
# Run via: just test-sql  (make test_debug)

require semantic_views

# ============================================================
# 1. Setup -- Create test tables with known data
# ============================================================

statement ok
CREATE TABLE test_orders (
    id INTEGER, region VARCHAR, category VARCHAR,
    amount DECIMAL(10,2), status VARCHAR, customer_id INTEGER
);

statement ok
INSERT INTO test_orders VALUES
    (1, 'EMEA', 'electronics', 100.00, 'completed', 1),
    (2, 'APAC', 'electronics', 200.00, 'completed', 2),
    (3, 'EMEA', 'clothing', 50.00, 'pending', 1),
    (4, 'APAC', 'clothing', 150.00, 'completed', 3),
    (5, 'EMEA', 'electronics', 75.00, 'completed', 2);

statement ok
CREATE TABLE test_customers (
    id INTEGER, name VARCHAR, tier VARCHAR
);

statement ok
INSERT INTO test_customers VALUES
    (1, 'Alice', 'gold'),
    (2, 'Bob', 'silver'),
    (3, 'Charlie', 'gold');

statement ok
CREATE TABLE test_products (
    category VARCHAR, supplier VARCHAR
);

statement ok
INSERT INTO test_products VALUES
    ('electronics', 'TechCorp'),
    ('clothing', 'FashionInc');

# ============================================================
# 2. Scenario 1: Basic round-trip (TEST-03, QUERY-01)
# ============================================================

# Define a basic semantic view over test_orders (single table)
statement ok
SELECT * FROM create_semantic_view(
    'simple_orders',
    tables := [{'alias': 'o', 'table': 'test_orders'}],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 'o'},
     {'name': 'category', 'expr': 'category', 'source_table': 'o'}],
    metrics := [{'name': 'total_revenue', 'expr': 'sum(amount)', 'source_table': 'o'},
     {'name': 'order_count', 'expr': 'count(*)', 'source_table': 'o'}]
);

# Query with single dimension + single metric (DECIMAL stays VARCHAR)
query TT rowsort
SELECT * FROM semantic_view('simple_orders', dimensions := ['region'], metrics := ['total_revenue']);
----
APAC	350.00
EMEA	225.00

# Query with all dimensions + all metrics
# total_revenue (DECIMAL) stays T; order_count (BIGINT count) is typed I
query TTTI rowsort
SELECT * FROM semantic_view('simple_orders', dimensions := ['region', 'category'], metrics := ['total_revenue', 'order_count']);
----
APAC	clothing	150.00	1
APAC	electronics	200.00	1
EMEA	clothing	50.00	1
EMEA	electronics	175.00	2

# ============================================================
# 3. Scenario 2: WHERE composition (QUERY-02)
# ============================================================

# Define a view with no built-in filter (filters via WHERE on query result)
statement ok
SELECT * FROM create_semantic_view(
    'filtered_orders',
    tables := [{'alias': 'o', 'table': 'test_orders'}],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 'o'}],
    metrics := [{'name': 'total_revenue', 'expr': 'sum(amount)', 'source_table': 'o'}]
);

query TT rowsort
SELECT * FROM semantic_view('filtered_orders', dimensions := ['region'], metrics := ['total_revenue']);
----
APAC	350.00
EMEA	225.00

# User WHERE composes with view result -- only EMEA orders
query TT rowsort
SELECT * FROM semantic_view('filtered_orders', dimensions := ['region'], metrics := ['total_revenue']) WHERE region = 'EMEA';
----
EMEA	225.00

# ============================================================
# 4. Scenario 4: Multi-table joins (QUERY-01 with joins, DDL-04)
# ============================================================

# Define a view joining orders -> customers and orders -> products.
# Expressions use UNQUALIFIED column names -- the CTE flattens joined tables.
# source_table uses alias (e.g., 'c') for join resolution; expand.rs resolves
# alias to physical name via def.tables and includes the join only when needed.
statement ok
SELECT * FROM create_semantic_view(
    'joined_orders',
    tables := [{'alias': 'o', 'table': 'test_orders'},
     {'alias': 'c', 'table': 'test_customers'},
     {'alias': 'p', 'table': 'test_products'}],
    relationships := [{'from_table': 'o', 'to_table': 'c',
      'join_columns': [{'from': 'customer_id', 'to': 'id'}]},
     {'from_table': 'o', 'to_table': 'p',
      'join_columns': [{'from': 'category', 'to': 'category'}]}],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 'o'},
     {'name': 'customer_tier', 'expr': 'tier', 'source_table': 'c'},
     {'name': 'supplier', 'expr': 'supplier', 'source_table': 'p'}],
    metrics := [{'name': 'total_revenue', 'expr': 'sum(amount)', 'source_table': 'o'},
     {'name': 'order_count', 'expr': 'count(*)', 'source_table': 'o'}]
);

# Query by customer_tier -- needs test_customers join only
# gold: Alice(100+50) + Charlie(150) = 300, silver: Bob(200+75) = 275
query TT rowsort
SELECT * FROM semantic_view('joined_orders', dimensions := ['customer_tier'], metrics := ['total_revenue']);
----
gold	300.00
silver	275.00

# Query by supplier -- needs test_products join only
# TechCorp(electronics): 3 orders, FashionInc(clothing): 2 orders
# order_count is BIGINT (typed I)
query TI rowsort
SELECT * FROM semantic_view('joined_orders', dimensions := ['supplier'], metrics := ['order_count']);
----
FashionInc	2
TechCorp	3

# ============================================================
# 5. Scenario 5: EXPLAIN equivalence via explain_semantic_view (EXPL-01)
# ============================================================

# TIP: EXPLAIN SELECT * FROM semantic_view('name', ...) shows DuckDB's
# physical plan (TABLE_FUNCTION node). Use explain_semantic_view('name', ...)
# to see the expanded SQL that semantic_view executes internally.

# Verify explain_semantic_view returns output with the expanded SQL
# The output should contain the view name and key SQL clauses
query T
SELECT * FROM explain_semantic_view('simple_orders', dimensions := ['region'], metrics := ['total_revenue']) WHERE explain_output = '-- Semantic View: simple_orders';
----
-- Semantic View: simple_orders

# Verify the expanded SQL contains the GROUP BY clause
query I
SELECT count(*) FROM explain_semantic_view('simple_orders', dimensions := ['region'], metrics := ['total_revenue']) WHERE explain_output LIKE '%GROUP BY%';
----
1

# Verify the DuckDB plan section contains a reference to the base table
# (appears in both the SQL and the execution plan)
query I
SELECT count(*) > 0 FROM explain_semantic_view('simple_orders', dimensions := ['region'], metrics := ['total_revenue']) WHERE explain_output LIKE '%test_orders%';
----
true

# ============================================================
# 6. Dimensions-only and metrics-only queries
# ============================================================

# Dimensions-only: should return DISTINCT values
query T rowsort
SELECT * FROM semantic_view('simple_orders', dimensions := ['region']);
----
APAC
EMEA

# Metrics-only: DECIMAL stays VARCHAR
query T
SELECT * FROM semantic_view('simple_orders', metrics := ['total_revenue']);
----
575.00

# Metrics-only with count: BIGINT typed as I
query I
SELECT * FROM semantic_view('simple_orders', metrics := ['order_count']);
----
5

# ============================================================
# 7. Error cases
# ============================================================

# Nonexistent view -- should error with "not found"
statement error
SELECT * FROM semantic_view('nonexistent', dimensions := ['x']);
----
not found

# Unknown dimension -- should error with "unknown dimension"
statement error
SELECT * FROM semantic_view('simple_orders', dimensions := ['nonexistent']);
----
unknown dimension

# No dimensions or metrics -- should error
statement error
SELECT * FROM semantic_view('simple_orders');
----
specify at least

# ============================================================
# 8. Typed output column tests (OUT-01)
# ============================================================

# Define a view with a count metric (BIGINT output, typed I)
statement ok
SELECT * FROM create_semantic_view(
    'typed_output_test',
    tables := [{'alias': 'o', 'table': 'test_orders'}],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 'o'}],
    metrics := [{'name': 'order_count', 'expr': 'count(*)', 'source_table': 'o'}]
);

# query TI confirms: region is VARCHAR (T), order_count is BIGINT (I)
query TI rowsort
FROM semantic_view('typed_output_test', dimensions := ['region'], metrics := ['order_count'])
----
APAC	2
EMEA	3

statement ok
SELECT * FROM drop_semantic_view('typed_output_test');

# DATE typed column test (OUT-01)
statement ok
CREATE TABLE test_events (
    event_date DATE,
    event_count INTEGER
);

statement ok
INSERT INTO test_events VALUES
    ('2024-01-15', 5),
    ('2024-02-20', 3);

statement ok
SELECT * FROM create_semantic_view(
    'typed_date_test',
    tables := [{'alias': 'e', 'table': 'test_events'}],
    time_dimensions := [{'name': 'event_date', 'expr': 'event_date', 'granularity': 'month'}],
    metrics := [{'name': 'total_count', 'expr': 'sum(event_count)', 'source_table': 'e'}]
);

# The time dimension returns DATE values (declared as DATE in bind()).
# SQLLogicTest does not support the 'D' specifier; 'T' reads any column as text.
# The metric total_count is sum(INTEGER) = BIGINT (typed I).
query TI rowsort
FROM semantic_view('typed_date_test', dimensions := ['event_date'], metrics := ['total_count'])
----
2024-01-01	5
2024-02-01	3

statement ok
SELECT * FROM drop_semantic_view('typed_date_test');

statement ok
DROP TABLE test_events;

# ============================================================
# 9. Cleanup -- drop views and tables for idempotency
# ============================================================

statement ok
SELECT * FROM drop_semantic_view('simple_orders');

statement ok
SELECT * FROM drop_semantic_view('filtered_orders');

statement ok
SELECT * FROM drop_semantic_view('joined_orders');

statement ok
DROP TABLE test_orders;

statement ok
DROP TABLE test_customers;

statement ok
DROP TABLE test_products;
