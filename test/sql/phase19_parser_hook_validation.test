# Phase 19: Parser Hook Validation Spike (updated for Phase 20)
# Originally confirmed which DDL prefixes trigger DuckDB's parser fallback hook.
# Now updated to reflect that Phase 20 implemented all 7 DDL prefix handlers.
#
# All 7 DDL prefixes now successfully route through the parser hook to their
# corresponding function calls. Prefixes 1-4 (DROP, DROP IF EXISTS,
# CREATE OR REPLACE, CREATE IF NOT EXISTS) work end-to-end.
# Prefixes 5-6 (DESCRIBE, SHOW) are detected but produce DDL errors until
# Plan 02 adds C++ result forwarding.
# Prefix 7 (CREATE) has always worked since v0.5.0.

require semantic_views

# ============================================================
# Setup: source table and existing semantic view
# ============================================================

statement ok
CREATE TABLE spike_source (region VARCHAR, amount DOUBLE);

statement ok
INSERT INTO spike_source VALUES ('East', 100.0), ('West', 200.0);

# Create a semantic view via the existing working native DDL (prefix 7)
statement ok
CREATE SEMANTIC VIEW spike_view (
    tables := [{'alias': 'sales', 'table': 'spike_source'}],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 'sales'}],
    metrics := [{'name': 'total', 'expr': 'SUM(amount)', 'source_table': 'sales'}]
);

# Verify the view works before testing other prefixes
query TT rowsort
SELECT * FROM semantic_view('spike_view', dimensions := ['region'], metrics := ['total']);
----
East	100.0
West	200.0

# ============================================================
# Prefix 1: DROP SEMANTIC VIEW -- now works (Phase 20)
# ============================================================

statement ok
DROP SEMANTIC VIEW spike_view;

# Re-create for further tests
statement ok
CREATE SEMANTIC VIEW spike_view (
    tables := [{'alias': 'sales', 'table': 'spike_source'}],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 'sales'}],
    metrics := [{'name': 'total', 'expr': 'SUM(amount)', 'source_table': 'sales'}]
);

# ============================================================
# Prefix 2: DROP SEMANTIC VIEW IF EXISTS -- now works (Phase 20)
# ============================================================

statement ok
DROP SEMANTIC VIEW IF EXISTS spike_view;

# Re-create for further tests
statement ok
CREATE SEMANTIC VIEW spike_view (
    tables := [{'alias': 'sales', 'table': 'spike_source'}],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 'sales'}],
    metrics := [{'name': 'total', 'expr': 'SUM(amount)', 'source_table': 'sales'}]
);

# ============================================================
# Prefix 3: CREATE OR REPLACE SEMANTIC VIEW -- now works (Phase 20)
# ============================================================

statement ok
CREATE OR REPLACE SEMANTIC VIEW spike_view (
    tables := [{'alias': 'sales', 'table': 'spike_source'}],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 'sales'}],
    metrics := [{'name': 'total', 'expr': 'SUM(amount)', 'source_table': 'sales'}]
);

# ============================================================
# Prefix 4: CREATE SEMANTIC VIEW IF NOT EXISTS -- now works correctly (Phase 20)
# Phase 19 spike showed this created a view named "IF" due to prefix overlap.
# Phase 20 fixed longest-prefix-first ordering, so this is now a correct no-op.
# ============================================================

statement ok
CREATE SEMANTIC VIEW IF NOT EXISTS spike_view (
    tables := [{'alias': 'sales', 'table': 'spike_source'}],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 'sales'}],
    metrics := [{'name': 'total', 'expr': 'SUM(amount)', 'source_table': 'sales'}]
);

# Verify no spurious "IF" view was created (Phase 19 bug is fixed)
query I
SELECT count(*) FROM list_semantic_views() WHERE name = 'IF';
----
0

# ============================================================
# Prefix 5: DESCRIBE SEMANTIC VIEW
# Detected by parser hook but result forwarding not yet implemented (Plan 02).
# The DDL executes describe_semantic_view() on sv_ddl_conn but the result
# is a single "view_name" column, not the full describe output.
# For now, this succeeds but returns only the view name.
# ============================================================

statement ok
DESCRIBE SEMANTIC VIEW spike_view;

# ============================================================
# Prefix 6: SHOW SEMANTIC VIEWS
# Detected by parser hook but result forwarding not yet implemented (Plan 02).
# The DDL executes list_semantic_views() on sv_ddl_conn but the result
# is a single "ok" column, not the full list output.
# For now, this succeeds but returns only "ok".
# ============================================================

statement ok
SHOW SEMANTIC VIEWS;

# ============================================================
# Prefix 7: CREATE SEMANTIC VIEW (existing, already working)
# Confirms the baseline still works.
# ============================================================

statement ok
CREATE SEMANTIC VIEW spike_view2 (
    tables := [{'alias': 'sales', 'table': 'spike_source'}],
    dimensions := [{'name': 'region', 'expr': 'region', 'source_table': 'sales'}],
    metrics := [{'name': 'total', 'expr': 'SUM(amount)', 'source_table': 'sales'}]
);

query TT rowsort
SELECT * FROM semantic_view('spike_view2', dimensions := ['region'], metrics := ['total']);
----
East	100.0
West	200.0

# ============================================================
# Cleanup
# ============================================================

statement ok
DROP TABLE spike_source;
