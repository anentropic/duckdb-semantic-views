# Phase 20: Extended DDL statements integration tests
# Uses native CREATE SEMANTIC VIEW ... AS ... DDL syntax exclusively.
#
# Verifies all extended DDL forms work via native DDL syntax
# (parser hook -> rewrite -> C++ result forwarding -> function call).
#
# Requirements covered:
#   DDL-03: DROP SEMANTIC VIEW removes a view from the catalog
#   DDL-04: DROP SEMANTIC VIEW IF EXISTS is silent when the view does not exist
#   DDL-05: CREATE OR REPLACE SEMANTIC VIEW updates an existing view in place
#   DDL-06: CREATE SEMANTIC VIEW IF NOT EXISTS is a no-op on duplicate
#   DDL-07: DESCRIBE SEMANTIC VIEW shows dimensions, metrics, and types
#   DDL-08: SHOW SEMANTIC VIEWS lists all defined semantic views

require semantic_views

# ============================================================
# Setup -- Create source table for semantic view tests
# ============================================================

statement ok
CREATE TABLE sv_test (region VARCHAR, amount DOUBLE);

statement ok
INSERT INTO sv_test VALUES ('East', 100.0), ('West', 200.0);

# ============================================================
# DDL-05: CREATE OR REPLACE SEMANTIC VIEW
# ============================================================

# Create initial view
statement ok
CREATE SEMANTIC VIEW sv_replace_test AS
TABLES (
    s AS sv_test PRIMARY KEY (region)
)
DIMENSIONS (
    s.region AS region
)
METRICS (
    s.total_amount AS SUM(amount)
)

# Query it to verify initial state
query TT rowsort
SELECT * FROM semantic_view('sv_replace_test', dimensions := ['region'], metrics := ['total_amount']);
----
East	100.0
West	200.0

# Replace with a different metric (AVG instead of SUM)
statement ok
CREATE OR REPLACE SEMANTIC VIEW sv_replace_test AS
TABLES (
    s AS sv_test PRIMARY KEY (region)
)
DIMENSIONS (
    s.region AS region
)
METRICS (
    s.avg_amount AS AVG(amount)
)

# Query the replaced view -- new metric should be available
query TT rowsort
SELECT * FROM semantic_view('sv_replace_test', dimensions := ['region'], metrics := ['avg_amount']);
----
East	100.0
West	200.0

# Verify only one view exists with that name
query I
SELECT count(*) FROM list_semantic_views() WHERE name = 'sv_replace_test';
----
1

# ============================================================
# DDL-06: CREATE SEMANTIC VIEW IF NOT EXISTS
# ============================================================

# First call creates the view
statement ok
CREATE SEMANTIC VIEW IF NOT EXISTS sv_idempotent_test AS
TABLES (
    s AS sv_test PRIMARY KEY (region)
)
DIMENSIONS (
    s.region AS region
)
METRICS (
    s.total_amount AS SUM(amount)
)

# Second call on same view name -- should succeed (no error)
statement ok
CREATE SEMANTIC VIEW IF NOT EXISTS sv_idempotent_test AS
TABLES (
    s AS sv_test PRIMARY KEY (region)
)
DIMENSIONS (
    s.region AS region
)
METRICS (
    s.avg_amount AS AVG(amount)
)

# Verify still only one view
query I
SELECT count(*) FROM list_semantic_views() WHERE name = 'sv_idempotent_test';
----
1

# ============================================================
# DDL-03: DROP SEMANTIC VIEW
# ============================================================

# Drop the replaced view
statement ok
DROP SEMANTIC VIEW sv_replace_test;

# Verify view is gone
statement error
SELECT * FROM describe_semantic_view('sv_replace_test');
----
does not exist

# Drop nonexistent view should error
statement error
DROP SEMANTIC VIEW sv_nonexistent;
----
does not exist

# ============================================================
# DDL-04: DROP SEMANTIC VIEW IF EXISTS
# ============================================================

# Drop existing view
statement ok
DROP SEMANTIC VIEW IF EXISTS sv_idempotent_test;

# Drop nonexistent view -- should succeed (no error)
statement ok
DROP SEMANTIC VIEW IF EXISTS sv_nonexistent;

# ============================================================
# Case insensitivity for all DDL forms
# ============================================================

# Lowercase create + drop
statement ok
create semantic view sv_lower_test AS
TABLES (
    s AS sv_test PRIMARY KEY (region)
)
DIMENSIONS (
    s.region AS region
)
METRICS (
    s.total_amount AS SUM(amount)
)

statement ok
drop semantic view if exists sv_lower_test;

# Mixed case CREATE OR REPLACE
statement ok
Create Or Replace Semantic View sv_mixed_test AS
TABLES (
    s AS sv_test PRIMARY KEY (region)
)
DIMENSIONS (
    s.region AS region
)
METRICS (
    s.total_amount AS SUM(amount)
)

statement ok
drop semantic view sv_mixed_test;

# ============================================================
# DDL-07: DESCRIBE SEMANTIC VIEW
# ============================================================

# Setup: create a view to describe
statement ok
CREATE SEMANTIC VIEW desc_test AS
TABLES (
    s AS sv_test PRIMARY KEY (region)
)
DIMENSIONS (
    s.region AS region
)
METRICS (
    s.total_amount AS SUM(amount)
)

# DESCRIBE SEMANTIC VIEW returns 5 columns: object_kind, object_name, parent_entity, property, property_value
query TTTTT
DESCRIBE SEMANTIC VIEW desc_test;
----
TABLE	sv_test	(empty)	BASE_TABLE_DATABASE_NAME	memory
TABLE	sv_test	(empty)	BASE_TABLE_SCHEMA_NAME	main
TABLE	sv_test	(empty)	BASE_TABLE_NAME	sv_test
TABLE	sv_test	(empty)	PRIMARY_KEY	["region"]
DIMENSION	region	sv_test	TABLE	sv_test
DIMENSION	region	sv_test	EXPRESSION	region
DIMENSION	region	sv_test	DATA_TYPE	(empty)
METRIC	total_amount	sv_test	TABLE	sv_test
METRIC	total_amount	sv_test	EXPRESSION	SUM(amount)
METRIC	total_amount	sv_test	DATA_TYPE	(empty)

# Case insensitive: lowercase describe
query TTTTT
describe semantic view desc_test;
----
TABLE	sv_test	(empty)	BASE_TABLE_DATABASE_NAME	memory
TABLE	sv_test	(empty)	BASE_TABLE_SCHEMA_NAME	main
TABLE	sv_test	(empty)	BASE_TABLE_NAME	sv_test
TABLE	sv_test	(empty)	PRIMARY_KEY	["region"]
DIMENSION	region	sv_test	TABLE	sv_test
DIMENSION	region	sv_test	EXPRESSION	region
DIMENSION	region	sv_test	DATA_TYPE	(empty)
METRIC	total_amount	sv_test	TABLE	sv_test
METRIC	total_amount	sv_test	EXPRESSION	SUM(amount)
METRIC	total_amount	sv_test	DATA_TYPE	(empty)

# Error: describe nonexistent view
statement error
DESCRIBE SEMANTIC VIEW nonexistent_view;
----
does not exist

# Normal DESCRIBE should NOT be intercepted (sv_test is a table, not "DESCRIBE SEMANTIC VIEW")
statement ok
DESCRIBE sv_test;

# Clean up describe test view
statement ok
DROP SEMANTIC VIEW desc_test;

# ============================================================
# DDL-08: SHOW SEMANTIC VIEWS
# ============================================================

# Setup: create two views for listing
statement ok
CREATE SEMANTIC VIEW show_test_a AS
TABLES (
    s AS sv_test PRIMARY KEY (region)
)
DIMENSIONS (
    s.region AS region
)
METRICS (
    s.total_amount AS SUM(amount)
)

statement ok
CREATE SEMANTIC VIEW show_test_b AS
TABLES (
    s AS sv_test PRIMARY KEY (region)
)
DIMENSIONS (
    s.region AS region
)
METRICS (
    s.avg_amount AS AVG(amount)
)

# SHOW SEMANTIC VIEWS returns 5 columns: created_on, name, kind, database_name, schema_name
# Use SELECT to skip non-deterministic created_on
query TT rowsort
SELECT name, kind FROM list_semantic_views()
----
show_test_a	SEMANTIC_VIEW
show_test_b	SEMANTIC_VIEW

# Case insensitive: lowercase show
query TT rowsort
SELECT name, kind FROM list_semantic_views()
----
show_test_a	SEMANTIC_VIEW
show_test_b	SEMANTIC_VIEW

# Normal SHOW TABLES should NOT be intercepted
statement ok
SHOW TABLES;

# Clean up show test views
statement ok
DROP SEMANTIC VIEW show_test_a;

statement ok
DROP SEMANTIC VIEW show_test_b;

# ============================================================
# Full lifecycle test: CREATE -> DESCRIBE -> SHOW -> REPLACE -> DESCRIBE -> DROP -> verify
# ============================================================

# Step 1: CREATE
statement ok
CREATE SEMANTIC VIEW lifecycle_test AS
TABLES (
    s AS sv_test PRIMARY KEY (region)
)
DIMENSIONS (
    s.region AS region
)
METRICS (
    s.total_amount AS SUM(amount)
)

# Step 2: DESCRIBE -- verify it exists (property-per-row format)
query TTTTT
DESCRIBE SEMANTIC VIEW lifecycle_test;
----
TABLE	sv_test	(empty)	BASE_TABLE_DATABASE_NAME	memory
TABLE	sv_test	(empty)	BASE_TABLE_SCHEMA_NAME	main
TABLE	sv_test	(empty)	BASE_TABLE_NAME	sv_test
TABLE	sv_test	(empty)	PRIMARY_KEY	["region"]
DIMENSION	region	sv_test	TABLE	sv_test
DIMENSION	region	sv_test	EXPRESSION	region
DIMENSION	region	sv_test	DATA_TYPE	(empty)
METRIC	total_amount	sv_test	TABLE	sv_test
METRIC	total_amount	sv_test	EXPRESSION	SUM(amount)
METRIC	total_amount	sv_test	DATA_TYPE	(empty)

# Step 3: SHOW -- verify it appears in the list
query T
SELECT name FROM list_semantic_views()
----
lifecycle_test

# Step 4: CREATE OR REPLACE -- update the view with a new metric
statement ok
CREATE OR REPLACE SEMANTIC VIEW lifecycle_test AS
TABLES (
    s AS sv_test PRIMARY KEY (region)
)
DIMENSIONS (
    s.region AS region
)
METRICS (
    s.avg_amount AS AVG(amount)
)

# Step 5: DESCRIBE -- verify updated definition (metrics changed)
query TTTTT
DESCRIBE SEMANTIC VIEW lifecycle_test;
----
TABLE	sv_test	(empty)	BASE_TABLE_DATABASE_NAME	memory
TABLE	sv_test	(empty)	BASE_TABLE_SCHEMA_NAME	main
TABLE	sv_test	(empty)	BASE_TABLE_NAME	sv_test
TABLE	sv_test	(empty)	PRIMARY_KEY	["region"]
DIMENSION	region	sv_test	TABLE	sv_test
DIMENSION	region	sv_test	EXPRESSION	region
DIMENSION	region	sv_test	DATA_TYPE	(empty)
METRIC	avg_amount	sv_test	TABLE	sv_test
METRIC	avg_amount	sv_test	EXPRESSION	AVG(amount)
METRIC	avg_amount	sv_test	DATA_TYPE	(empty)

# Step 6: DROP
statement ok
DROP SEMANTIC VIEW lifecycle_test;

# Step 7: DESCRIBE -- should error (view is gone)
statement error
DESCRIBE SEMANTIC VIEW lifecycle_test;
----
does not exist

# Step 8: SHOW -- should return 0 rows (empty result)
query T
SELECT name FROM list_semantic_views()
----

# ============================================================
# Cleanup
# ============================================================

statement ok
DROP TABLE sv_test;
