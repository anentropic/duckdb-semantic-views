# RT-3 / TC-3 (code-review 2026-07-02): end-to-end coverage for a quoted,
# non-ASCII, whitespace-bearing view name through the full lifecycle:
# CREATE -> query -> DESCRIBE -> GET_DDL -> DROP.
#
# Exercises PA-2 (UTF-8 identifier storage), PA-8 (quoted-name case/content
# preservation), and RT-2 (render_ddl re-quotes the name so GET_DDL output
# re-parses to the same catalog key).

require semantic_views

statement ok
CREATE TABLE rtw_orders (id INTEGER PRIMARY KEY, amount DECIMAL(10,2), city VARCHAR);

statement ok
INSERT INTO rtw_orders VALUES (1, 100.00, 'São Paulo'), (2, 50.00, 'Tōkyō');

statement ok
CREATE SEMANTIC VIEW "wéird name" AS
  TABLES (o AS rtw_orders PRIMARY KEY (id))
  DIMENSIONS (o.city AS o.city COMMENT = 'cidade / 都市')
  METRICS (o.total AS SUM(o.amount));

# Name stored exactly as quoted (no mojibake, case/space preserved).
query I
SELECT name FROM list_semantic_views();
----
wéird name

# Query through the quoted lookup argument.
query II
FROM semantic_view('"wéird name"', dimensions := ['city'], metrics := ['total'])
ORDER BY 1;
----
São Paulo	100.00
Tōkyō	50.00

# DESCRIBE with the quoted identifier.
statement ok
DESCRIBE SEMANTIC VIEW "wéird name";

# Non-ASCII COMMENT payload survives storage and DESCRIBE output (PA-2).
query I
SELECT count(*) FROM describe_semantic_view('wéird name')
WHERE property = 'COMMENT' AND property_value = 'cidade / 都市';
----
1

# GET_DDL emits a re-quoted header that re-parses to the same name.
query I
SELECT GET_DDL('SEMANTIC_VIEW', 'wéird name') LIKE '%CREATE OR REPLACE SEMANTIC VIEW "wéird name"%';
----
true

# The non-ASCII comment survives into the rendered DDL.
query I
SELECT GET_DDL('SEMANTIC_VIEW', 'wéird name') LIKE '%cidade / 都市%';
----
true

statement ok
DROP SEMANTIC VIEW "wéird name";

query I
SELECT count(*) FROM list_semantic_views();
----
0

# ---------------------------------------------------------------------------
# AR-2 coverage rebuild: a view name containing a single quote must survive the
# full CREATE -> ALTER RENAME -> ALTER SET COMMENT -> DROP lifecycle. Each DDL
# emits native DML with the name embedded as a SQL string literal, so this
# exercises escape_sql_arg's quote-doubling ('it''s_ok') at the emission
# boundary end-to-end. (Before AR-2 this was pinned by unit assertions on the
# generated fn-call string; that assertion moved here when RewriteAction became
# the parser's structured output and names are carried raw.)
# ---------------------------------------------------------------------------

statement ok
CREATE SEMANTIC VIEW "it's_ok" AS
  TABLES (o AS rtw_orders PRIMARY KEY (id))
  DIMENSIONS (o.city AS o.city)
  METRICS (o.total AS SUM(o.amount));

# Name stored with the literal single quote (not doubled) in the catalog.
query I
SELECT name FROM list_semantic_views();
----
it's_ok

# Query lookup with the quoted-identifier argument (single quote doubled in the
# SQL string literal argument).
query II
FROM semantic_view('"it''s_ok"', dimensions := ['city'], metrics := ['total'])
ORDER BY 1;
----
São Paulo	100.00
Tōkyō	50.00

# ALTER RENAME embeds BOTH the old and new single-quote names in the UPDATE +
# guard SQL.
statement ok
ALTER SEMANTIC VIEW "it's_ok" RENAME TO "it's_fine";

query I
SELECT name FROM list_semantic_views();
----
it's_fine

# ALTER SET COMMENT: name in the guard/UPDATE WHERE, and a comment that itself
# contains a single quote (json_merge_patch path).
statement ok
ALTER SEMANTIC VIEW "it's_fine" SET COMMENT = 'it''s a comment';

query I
SELECT count(*) FROM describe_semantic_view('it''s_fine')
WHERE property = 'COMMENT' AND property_value = 'it''s a comment';
----
1

# DROP embeds the single-quote name in the DELETE + existence guard.
statement ok
DROP SEMANTIC VIEW "it's_fine";

query I
SELECT count(*) FROM list_semantic_views();
----
0
