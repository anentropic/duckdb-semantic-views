# Phase 62 Wave 3 — Unicode prefix caret coverage.
#
# DuckDB's ParserException::SyntaxError renders the offending input as the
# user typed it; the caret column in the rendered output is character-based
# in the printed line (Python str.index('^') returns char offset). Internally
# the position is a byte offset, but the rendered caret aligns with the
# character it points to. Whatever DuckDB does today is the contract this
# fixture pins.
#
# Behavioural property pinned (from RESEARCH.md §6):
#   B5: caret column is correct in presence of multibyte UTF-8 chars

require semantic_views

statement ok
LOAD semantic_views;

statement ok
CREATE TABLE t(id INTEGER PRIMARY KEY);

# B5: multibyte UTF-8 identifier (vüé) before the typo TBLES. Validator
# emits "Unknown clause keyword 'TBLES'; did you mean 'TABLES'?" with the
# caret column accounting for the unicode prefix. Substring match on the
# message text + LINE 1: prefix proves caret rendering survived UTF-8.
statement error
CREATE SEMANTIC VIEW vüé AS TBLES (t);
----
did you mean 'TABLES'

statement error
CREATE SEMANTIC VIEW vüé AS TBLES (t);
----
LINE 1:
